# App
PROJECT_NAME="Agentic SQL Assistant"
APP_ENV=development # development | staging | production
DEBUG=true
API_V1_STR="/api/v1"
SECRET_KEY="change_this_to_a_secure_random_string" # For JWT

# Database (PostgreSQL - App State)
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agentic_db
POSTGRES_PORT=5432

# Database (Target SQL Server - Read Only)
# If using docker, efficient way is to use host.docker.internal or IP
SQL_SERVER_HOST=host.docker.internal
SQL_SERVER_DB=AdventureWorks
SQL_SERVER_USER=sa
SQL_SERVER_PASSWORD=yourStrong(!)Password
SQL_SERVER_DRIVER="ODBC Driver 17 for SQL Server"

# AI
OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_VERSION="2024-02-15-preview"
AZURE_DEPLOYMENT_NAME="gpt-4"
MAX_TOKENS=4000

# Rate Limiting
RATE_LIMIT_DEFAULT="100/minute"
