ng\":\"التدريب\",\"status\":\"الحالة\",\"community\":\"المجتمع\"}},\"legal\":{\"title\":\"القانوني\",\"links\":{\"privacy\":\"الخصوصية\",\"terms\":\"الشروط\",\"hipaa\":\"HIPAA\",\"security\":\"الأمان\",\"responsible_disclosure\":\"الإفصاح المسؤول\"}}}}},\"consultations\":{\"video_consultations\":{\"meta\":{\"title\":\"برنامج استشارة الفيديو للرعاية الصحية عن بعد - ContinuousCare | حلول الرعاية الصحية\",\"description\":\"برنامج استشارة الفيديو الاحترافي للرعاية الصحية عن بعد مع مكالمات فيديو عالية الدقة، وغرف انتظار افتراضية، ومشاركة الشاشة، وجلسات متعددة المشاركين، وتكامل سلس مع السجل الصحي الإلكتروني للممارسات الطبية.\",\"og_title\":\"برنامج استشارة الفيديو للرعاية الصحية عن بعد - ContinuousCare\",\"og_description\":\"برنامج استشارة الفيديو الاحترافي للرعاية الصحية عن بعد مع مكالمات فيديو عالية الدقة وتكامل مع السجل الصحي الإلكتروني\"},\"structured_data\":{\"faq_questions\":[{\"question\":\"كيف تعمل استشارات الفيديو للرعاية الصحية عن بعد في الممارسة الافتراضية؟\",\"answer\":\"يحجز المرضى ويدفعون مقابل زيارات الفيديو من خلال بوابتك أو تطبيق الهاتف المحمول. في الوقت المحدد، يقومون بتسجيل الدخول والانضمام بشكل آمن. يرى مقدمو الخدمة الموعد في تقويمهم، ويصلون إلى السجل الصحي للمريض أثناء المكالمة، ويأخذون ملاحظات، ويقومون بإنشاء مستندات الاستشارة أو الوصفات الطبية أو أوامر المختبر بعد ذلك.\"},{\"question\":\"هل يتلقى المرضى ومقدمو الخدمة تذكيرات حول استشارات الفيديو؟\",\"answer\":\"نعم. يتم إرسال تذكيرات تلقائية لمواعيد الرعاية الصحية عن بعد المجدولة والمدفوعات والمتابعات. يمكن تسليم الإشعارات عبر البريد الإلكتروني أو الرسائل القصيرة أو الإشعارات الفورية لتقليل الغياب وإبقاء الجميع مستعدين.\"},{\"question\":\"هل يحتاج المرضى إلى تطبيقات خاصة لزيارات الرعاية الصحية عن بعد؟\",\"answer\":\"لا. يقوم المرضى ببساطة بتسجيل الدخول من خلال بوابة المريض ذات العلامة التجارية أو تطبيق الهاتف المحمول. تعمل استشارات الفيديو للرعاية الصحية عن بعد مباشرة داخل الممارسة الافتراضية - لا حاجة لتنزيلات من جهات خارجية.\"},{\"question\":\"هل يمكنني إصدار فواتير لزيارات الرعاية الصحية عن بعد بنفس طريقة الاستشارات الشخصية؟\",\"answer\":\"نعم. يتم تحديد مواعيد الرعاية الصحية عن بعد مثل الخدمات الشخصية. يمكنك تحديد المدة ورسوم الخدمة والضرائب؛ يدفع المرضى عبر الإنترنت؛ ويتم إنشاء سجلات الفواتير تلقائياً.\"},{\"question\":\"ماذا يحدث للملاحظات من استشارة الفيديو؟\",\"answer\":\"يتم تخزين الملاحظات المأخوذة أثناء استشارة الفيديو في سجل اللقاء. يمكن لمقدمي الخدمة استخدامها لإنشاء مستندات الاستشارة أو الوصفات الطبية أو أوامر المختبر. إذا تم استخدام AI Scribe، يتم تضمين هذه الملاحظات كسياق لإنشاء التوثيق السريري.\"},{\"question\":\"هل يمكن لأكثر من شخص واحد الانضمام إلى مكالمة الرعاية الصحية عن بعد؟\",\"answer\":\"نعم. يمكن لمقدمي الخدمة دعوة مقدمي الرعاية أو المترجمين أو المشاركين الإضافيين لمكالمات الفيديو الفورية. يتيح وضع الفيديو المساعد أيضاً للممرضات أو الموظفين مساعدة المرضى في المناطق النائية على الاتصال بمقدم الخدمة الخاص بهم.\"},{\"question\":\"هل استشارات الفيديو للرعاية الصحية عن بعد آمنة ومتوافقة؟\",\"answer\":\"نعم. جميع زيارات الرعاية الصحية عن بعد مشفرة ومتوافقة مع HIPAA و GDPR ولوائح الرعاية الصحية الأخرى. العلامة البيضاء اختيارية - قد تحتفظ بالمظهر القياسي أو تخصص البوابة والتطبيقات لتعكس علامتك التجارية.\"},{\"question\":\"ما المعدات التي يحتاجها المرضى لزيارات الرعاية الصحية عن بعد؟\",\"answer\":\"يكفي هاتف ذكي أو جهاز لوحي أو كمبيوتر مزود بكاميرا واتصال إنترنت موثوق. لا حاجة لأجهزة إضافية لمعظم استشارات الفيديو.\"}],\"product\":{\"name\":\"استشارات فيديو الممارسة الافتراضية\",\"alternateName\":\"منصة الرعاية الصحية عن بعد والطب عن بعد\",\"brand\":\"ContinuousCare\",\"description\":\"تتيح الممارسة الافتراضية ContinuousCare استشارات الفيديو الآمنة للرعاية الصحية عن بعد والطب عن بعد للعيادات والممارسات الصغيرة والشركات الناشئة في مجال الصحة الرقمية. يمكن للمرضى الحجز والدفع والانضمام إلى الزيارات عبر الإنترنت من خلال تطبيقات الويب أو الهاتف المحمول، بينما يدير مقدمو الخدمة الجدولة والفواتير والسجلات الصحية في نظام متكامل واحد.\",\"category\":\"برنامج الرعاية الصحية عن بعد\",\"audience\":\"مقدمو الرعاية الصحية، العيادات، الشركات الناشئة في مجال الصحة الرقمية\",\"keywords\":\"الرعاية الصحية عن بعد، الطب عن بعد، استشارات الفيديو، منصة الرعاية الافتراضية، SaaS للرعاية الصحية، رعاية المرضى عن بعد\"}},\"hero\":{\"title\":\"برنامج استشارة الفيديو للرعاية الصحية عن بعد: \",\"title_highlight\":\"رعاية احترافية\",\"title_suffix\":\" في أي مكان\",\"subtitle\":\"تقديم الرعاية من خلال زيارات الطب عن بعد الآمنة، متكاملة بالكامل مع المواعيد والفواتير والسجلات الصحية في ممارستك الافتراضية.\",\"cta_text\":\"ابدأ النسخة التجريبية المجانية\",\"image_alt\":\"مقدم رعاية صحية يجري استشارة فيديو AI Scribe\"},\"problem_section\":{\"title\":\"لماذا تهم استشارات الفيديو\",\"features\":[{\"title\":\"رعاية صحية عن بعد متاحة في أي مكان\",\"description\":\"لا يحتاج المرضى إلى تأجيل الرعاية أو الاعتماد فقط على الأدوات الرقمية - تسهل زيارات الطب عن بعد الآمنة الاتصال من أي مكان.\"},{\"title\":\"علاقات أقوى مع المرضى\",\"description\":\"ابقَ على اتصال بين الزيارات مع إرشادات موثوقة للرعاية الصحية عن بعد وتواصل مستمر.\"},{\"title\":\"ممارسة جاهزة للمستقبل\",\"description\":\"قدّم خدمات الطب عن بعد المرنة إلى جانب الرعاية الشخصية، مع الحفاظ على ممارستك حديثة في عصر الذكاء الاصطناعي.\"}]},\"seamless_access\":{\"badge\":\"وصول سلس للمرضى\",\"title\":\"وصول سلس للمرضى\",\"subtitle\":\"يحجز المرضى ويدفعون مقابل زيارات الفيديو من خلال البوابة أو التطبيق، ثم يقومون ببساطة بتسجيل الدخول والانضمام إلى المكالمة في وقت الموعد.\",\"features\":[\"يحجز المرضى ويدفعون مقابل زيارات الفيديو من خلال البوابة أو التطبيق.\",\"في الوقت المحدد للموعد، يقومون ببساطة بتسجيل الدخول والانضمام إلى المكالمة.\",\"يرى مقدمو الخدمة استشارات الفيديو في جدولهم مثل أي خدمة أخرى.\"],\"image_alt\":\"مريض يحجز ويصل إلى استشارة فيديو من خلال البوابة\"},\"clinical_workflow\":{\"badge\":\"سير عمل سريري متكامل\",\"title\":\"سير عمل سريري متكامل\",\"subtitle\":\"أكمل التوثيق السريري مع الملاحظات والوصفات الطبية والفواتير المتكاملة بسلاسة في سير العمل الحالي الخاص بك.\",\"features\":[\"يمكن لمقدمي الخدمة عرض السجل الصحي للمريض أثناء المكالمة.\",\"خذ ملاحظات في الوقت الفعلي، والتي تتدفق إلى سجل اللقاء.\",\"بعد المكالمة، أنشئ مستندات الاستشارة أو الوصفات الطبية أو أوامر المختبر.\",\"الملاحظات متاحة لـ AI Scribe إذا تم استخدامها لإنشاء مستندات الاستشارة.\"],\"image_alt\":\"سير عمل سريري متكامل أثناء استشارة الفيديو\"},\"consultation_options\":{\"badge\":\"خيارات استشارة مرنة\",\"title\":\"خيارات استشارة مرنة\",\"subtitle\":\"دعم أنواع مختلفة من الاستشارات من الزيارات المجدولة إلى المكالمات الفورية وأوضاع الفيديو المساعدة لمختلف احتياجات المرضى.\",\"options\":[{\"title\":\"الزيارات المجدولة\",\"description\":\"يتم تحديدها حسب مدة الخدمة (على سبيل المثال، 15 أو 30 دقيقة) مع إمكانية التمديد.\"},{\"title\":\"المكالمات الفورية\",\"description\":\"مكالمات سريعة بدون موعد مع مشاركين إضافيين اختياريين (مقدمو الرعاية، المترجمون، إلخ).\"},{\"title\":\"وضع الفيديو المساعد\",\"description\":\"يمكن للممرضات أو الموظفين مساعدة المرضى في المواقع النائية أو منخفضة التقنية على الانضمام إلى المكالمات مع مقدمي الخدمة.\"}],\"image_alt\":\"خيارات استشارة الفيديو المرنة لاحتياجات المرضى المختلفة\"},\"collaboration\":{\"badge\":\"التعاون أصبح بسيطاً\",\"title\":\"التعاون أصبح بسيطاً\",\"subtitle\":\"تمكين التواصل الفعال والتعاون أثناء الاستشارات مع مشاركة الشاشة ودعم المشاركين المتعددين.\",\"features\":[\"مشاركة الشاشة أثناء المكالمات لشرح التقارير أو النتائج أو خطط العلاج.\",\"تتيح المكالمات متعددة المشاركين الرعاية الشاملة مع مقدمي الرعاية أو موظفي الدعم المشاركين.\"],\"image_alt\":\"مشاركة الشاشة والتعاون متعدد المشاركين أثناء استشارة الفيديو\"},\"security\":{\"badge\":\"آمن ومتوافق وقابل للتوسع\",\"title\":\"أمان وامتثال على مستوى المؤسسة\",\"features\":[\"مكالمات فيديو مشفرة متوافقة مع HIPAA/GDPR.\",\"مصممة لممارسات الرعاية الصحية بجميع أحجامها.\",\"بنية تحتية قابلة للتوسع للعيادات الصغيرة والتوزيعات المؤسسية.\"],\"image_alt\":\"استشارات فيديو آمنة متوافقة مع HIPAA مع علامة بيضاء\"},\"digital_health_startups\":{\"badge\":\"للشركات الناشئة في مجال الصحة الرقمية\",\"title\":\"للشركات الناشئة في مجال الصحة الرقمية\",\"subtitle\":\"احصل على خدمتك جاهزة بسرعة مع ممارس