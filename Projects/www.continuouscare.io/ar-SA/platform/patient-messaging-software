0-4 4v2"></path><path d="M16 3.128a4 4 0 0 1 0 7.744"></path><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><circle cx="9" cy="7" r="4"></circle></svg></div><h3 class="text-xl font-bold text-slate-dark mb-4">وصول سهل لمقدمي رعاية موثوقين</h3><p class="text-slate-600 leading-relaxed">يمكن للمرضى طرح الأسئلة مباشرة بدلاً من اللجوء فقط إلى الذكاء الاصطناعي أو محركات البحث.</p></div><div class="bg-white rounded-2xl shadow-lg p-8 text-center"><div class="w-16 h-16 mx-auto mb-6 rounded-full bg-purple-accent/10 flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield h-8 w-8 text-purple-accent" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path></svg></div><h3 class="text-xl font-bold text-slate-dark mb-4">تواصل آمن واحترافي</h3><p class="text-slate-600 leading-relaxed">يبقي المناقشات الصحية بعيداً عن الرسائل القصيرة أو واتساب أو البريد الإلكتروني.</p></div><div class="bg-white rounded-2xl shadow-lg p-8 text-center"><div class="w-16 h-16 mx-auto mb-6 rounded-full bg-green-success/10 flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-square h-8 w-8 text-green-success" aria-hidden="true"><path d="M22 17a2 2 0 0 1-2 2H6.828a2 2 0 0 0-1.414.586l-2.202 2.202A.71.71 0 0 1 2 21.286V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2z"></path></svg></div><h3 class="text-xl font-bold text-slate-dark mb-4">علاقات أقوى مع المرضى</h3><p class="text-slate-600 leading-relaxed">يبني الثقة واستمرارية الرعاية بين الزيارات.</p></div><div class="bg-white rounded-2xl shadow-lg p-8 text-center"><div class="w-16 h-16 mx-auto mb-6 rounded-full bg-teal-primary/10 flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock h-8 w-8 text-teal-primary" aria-hidden="true"><path d="M12 6v6l4 2"></path><circle cx="12" cy="12" r="10"></circle></svg></div><h3 class="text-xl font-bold text-slate-dark mb-4">تحكم مقدم الرعاية</h3><p class="text-slate-600 leading-relaxed">أنت تقرر نوافذ الرد، مما يضمن بقاء التواصل قابلاً للإدارة.</p></div></div></div></div></div></section><section class="py-16 bg-white"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center transition-all duration-700 opacity-0 translate-y-10"><div class="lg:w-full space-y-8"><div class="inline-block"><span class="bg-blue-light/20 text-blue-vibrant px-4 py-2 rounded-full text-sm font-medium border border-blue-vibrant/30">مراسلة الصحة عن بُعد غير المتزامنة</span></div><div><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-dark mb-6 leading-tight">مراسلة الصحة عن بُعد غير المتزامنة</h2><p class="text-xl text-slate-600 leading-relaxed max-w-xl">نظام مراسلة مرضى آمن حيث يقدم المرضى الأسئلة مع السياق، ويرد مقدمو الرعاية ضمن نوافذ رد محددة — رعاية منظمة، وليس دردشة فورية.</p></div><div class="grid grid-cols-1 md:grid-cols-2 gap-8"><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-square h-6 w-6 text-blue-vibrant flex-shrink-0 mt-1" aria-hidden="true"><path d="M22 17a2 2 0 0 1-2 2H6.828a2 2 0 0 0-1.414.586l-2.202 2.202A.71.71 0 0 1 2 21.286V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2z"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">تقديم أسئلة المريض</h3><p class="text-slate-600 text-sm">يرسل المرضى أسئلة صحية عبر البوابة أو التطبيق، مع خيار إرفاق التقارير أو الصور.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock h-6 w-6 text-blue-vibrant flex-shrink-0 mt-1" aria-hidden="true"><path d="M12 6v6l4 2"></path><circle cx="12" cy="12" r="10"></circle></svg><div><h3 class="font-semibold text-slate-800 mb-1">نظام رد مقدم الرعاية</h3><p class="text-slate-600 text-sm">يرد مقدمو الرعاية حسب جدولهم ضمن أطر زمنية محددة، مما يحافظ على كفاءة الرعاية وقابليتها للإدارة.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text h-6 w-6 text-blue-vibrant flex-shrink-0 mt-1" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path><path d="M14 2v4a2 2 0 0 0 2 2h4"></path><path d="M10 9H8"></path><path d="M16 13H8"></path><path d="M16 17H8"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">سير عمل متكامل</h3><p class="text-slate-600 text-sm">جميع الأسئلة والأجوبة مخزنة في السجل الصحي للمريض، لدعم استمرارية الرعاية.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-database h-6 w-6 text-blue-vibrant flex-shrink-0 mt-1" aria-hidden="true"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M3 5V19A9 3 0 0 0 21 19V5"></path><path d="M3 12A9 3 0 0 0 21 12"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">لوحة إدارة الأسئلة</h3><p class="text-slate-600 text-sm">يتتبع مقدمو الرعاية والفرق أسئلة المرضى ويحددون الأولويات ويديرونها في عرض منظم واحد.</p></div></div></div></div></div><div class="lg:w-full"><div class="relative"><img alt="Async telehealth messaging interface" loading="lazy" width="600" height="400" decoding="async" data-nimg="1" class="rounded-2xl shadow-2xl w-full object-cover aspect-4/3" style="color:transparent" srcSet="/_next/image?url=%2Fpatient_messaging%2Fasynchronous-telehealth-messaging.png&amp;w=640&amp;q=75 1x, /_next/image?url=%2Fpatient_messaging%2Fasynchronous-telehealth-messaging.png&amp;w=1200&amp;q=75 2x" src="/_next/image?url=%2Fpatient_messaging%2Fasynchronous-telehealth-messaging.png&amp;w=1200&amp;q=75"/></div></div></div></div></section><section class="py-16 bg-gray-50"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center transition-all duration-700 opacity-0 translate-y-10"><div class="lg:w-full lg:order-1"><div class="relative"><img alt="Integrated payment processing for patient messaging" loading="lazy" width="600" height="400" decoding="async" data-nimg="1" class="rounded-2xl shadow-2xl w-full object-cover aspect-4/3" style="color:transparent" srcSet="/_next/image?url=%2Fpatient_messaging%2Fintegrated-payments-for-patient-messaging.jpg&amp;w=640&amp;q=75 1x, /_next/image?url=%2Fpatient_messaging%2Fintegrated-payments-for-patient-messaging.jpg&amp;w=1200&amp;q=75 2x" src="/_next/image?url=%2Fpatient_messaging%2Fintegrated-payments-for-patient-messaging.jpg&amp;w=1200&amp;q=75"/></div></div><div class="lg:w-full space-y-8 lg:order-2"><div class="inline-block"><span class="bg-green-success/20 text-green-success px-4 py-2 rounded-full text-sm font-medium border border-green-success/30">مدفوعات متكاملة</span></div><div><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-dark mb-6 leading-tight">مدفوعات متكاملة لمراسلة المرضى</h2><p class="text-xl text-slate-600 leading-relaxed max-w-xl">حوّل وقت مقدم الرعاية إلى رعاية معوضة — كل لقاء مراسلة يمكن إصدار فاتورة به وتتبعه ودفعه من خلال عيادتك الافتراضية.</p></div><div class="grid grid-cols-1 md:grid-cols-2 gap-8"><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-dollar-sign h-6 w-6 text-green-success flex-shrink-0 mt-1" aria-hidden="true"><line x1="12" x2="12" y1="2" y2="22"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">تسعير لكل مقدم رعاية</h3><p class="text-slate-600 text-sm">حدد رسوم خدمة مختلفة لكل مقدم رعاية، بناءً على دوره أو تخصصه.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-credit-card h-6 w-6 text-green-success flex-shrink-0 mt-1" aria-hidden="true"><rect width="20" height="14" x="2" y="5" rx="2"></rect><line x1="2" x2="22" y1="10" y2="10"></line></svg><div><h3 class="font-semibold text-slate-800 mb-1">فوترة ومدفوعات تلقائية</h3><p class="text-slate-600 text-sm">يتم إنشاء الفواتير تلقائياً للقاءات المراسلة. يدفع المرضى بشكل آمن عبر الإنترنت، وتذهب الأموال مباشرة إلى حساب عيادتك.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text h-6 w-6 text-green-success flex-shrink-0 mt-1" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path><path d="M14 2v4a2 2 0 0 0 2 2h4"></path><path d="M10 9H8"></path><path d="M16 13H8"></path><path d="M16 17H8"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">ملاحظات متابعة قابلة للتكوين</h3><p class="text-slate-600 text-sm">اسمح بعدد محدد من ردود المتابعة ليتم تضمينها في رسوم لقاء واحد. يمكن إصدار فواتير منفصلة للملاحظات الإضافية إذا لزم الأمر.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-zap h-6 w-6 text-green-success flex-shrink-0 mt-1" aria-hidden="true"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">قيمة عادلة لوقت مقدم الرعاية</h3><p class="text-slate-600 text-sm">لا مزيد من المكالمات أو الرسائل النصية أو رسائل واتساب غير المدفوعة. يتم تعويض وقت مقدم الرعاية بشكل صحيح من خلال المراسلة المنظمة القابلة للفوترة.</p></div></div></div></div></div></div></div></section><section class="py-16 bg-white"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center transition-all duration-700 opacity-0 translate-y-10"><div class="lg:w-full space-y-8"><div class="inline-block"><span class="bg-purple-light/20 text-purple-accent px-4 py-2 rounded-full text-sm font-medium border border-purple-accent/30">سير عمل العيادة المتكامل</span></div><div><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-dark mb-6 leading-tight">سير عمل العيادة المتكامل</h2><p class="text-xl text-slate-600 leading-relaxed max-w-xl">مراسلة المرضى ليست أداة معزولة — إنها جزء من عيادتك الافتراضية، مما يضمن أن كل رسالة آمنة وسياقية وقابلة للتنفيذ.</p></div><div class="grid grid-cols-1 md:grid-cols-2 gap-8"><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-activity h-6 w-6 text-purple-accent flex-shrink-0 mt-1" aria-hidden="true"><path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">ردود غنية بالسياق</h3><p class="text-slate-600 text-sm">يرد مقدمو الرعاية بسياق كامل من السجل الصحي للمريض، بما في ذلك بيانات متتبع الصحة والاستشارات السابقة.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text h-6 w-6 text-purple-accent flex-shrink-0 mt-1" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path><path d="M14 2v4a2 2 0 0 0 2 2h4"></path><path d="M10 9H8"></path><path d="M16 13H8"></path><path d="M16 17H8"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">سجل دائم</h3><p class="text-slate-600 text-sm">يتم حفظ الأسئلة والردود في سجل المريض للرجوع إليها في المستقبل ولاستمرارية الرعاية.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-zap h-6 w-6 text-purple-accent flex-shrink-0 mt-1" aria-hidden="true"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">سير عمل قابل للتنفيذ</h3><p class="text-slate-600 text-sm">من أي رسالة، يمكن لمقدمي الرعاية جدولة موعد أو إضافة وثيقة استشارة أو وصف دواء أو تعيين المريض لخطة رعاية.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users h-6 w-6 text-purple-accent flex-shrink-0 mt-1" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><path d="M16 3.128a4 4 0 0 1 0 7.744"></path><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><circle cx="9" cy="7" r="4"></circle></svg><div><h3 class="font-semibold text-slate-800 mb-1">تسجيل مرضى جدد</h3><p class="text-slate-600 text-sm">يتم تسجيل الباحثين عن رأي ثانٍ أو جهات الاتصال لأول مرة بسلاسة كمرضى مسجلين من خلال البوابة.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bell h-6 w-6 text-purple-accent flex-shrink-0 mt-1" aria-hidden="true"><path d="M10.268 21a2 2 0 0 0 3.464 0"></path><path d="M3.262 15.326A1 1 0 0 0 4 17h16a1 1 0 0 0 .74-1.673C19.41 13.956 18 12.499 18 8A6 6 0 0 0 6 8c0 4.499-1.411 5.956-2.738 7.326"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">إشعارات تلقائية</h3><p class="text-slate-600 text-sm">يتم تنبيه مقدمي الرعاية عند وصول أسئلة جديدة؛ ويتم إخطار المرضى عندما تكون الردود جاهزة — عبر البريد الإلكتروني أو الرسائل النصية أو إشعارات التطبيق الفورية.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-credit-card h-6 w-6 text-purple-accent flex-shrink-0 mt-1" aria-hidden="true"><rect width="20" height="14" x="2" y="5" rx="2"></rect><line x1="2" x2="22" y1="10" y2="10"></line></svg><div><h3 class="font-semibold text-slate-800 mb-1">فوترة متكاملة</h3><p class="text-slate-600 text-sm">كل لقاء يمكن أن ينشئ فاتورة تلقائياً، مع تحصيل المدفوعات عبر الإنترنت وتحويلها مباشرة إلى حساب العيادة.</p></div></div></div></div></div><div class="lg:w-full"><div class="relative"><img alt="Integrated practice workflow dashboard" loading="lazy" width="600" height="400" decoding="async" data-nimg="1" class="rounded-2xl shadow-2xl w-full object-cover aspect-4/3" style="color:transparent" srcSet="/_next/image?url=%2Fpatient_messaging%2Fintegrated-practice-workflow.jpg&amp;w=640&amp;q=75 1x, /_next/image?url=%2Fpatient_messaging%2Fintegrated-practice-workflow.jpg&amp;w=1200&amp;q=75 2x" src="/_next/image?url=%2Fpatient_messaging%2Fintegrated-practice-workflow.jpg&amp;w=1200&amp;q=75"/></div></div></div></div></section><section class="py-16 bg-gray-50"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center transition-all duration-700"><div class="lg:w-full lg:order-1"><div class="relative"><img alt="Secure and compliant communication platform" loading="lazy" width="600" height="400" decoding="async" data-nimg="1" class="rounded-2xl shadow-2xl w-full object-cover aspect-4/3" style="color:transparent" srcSet="/_next/image?url=%2Fpatient_messaging%2Fsecure-and-compliant-communication.jpg&amp;w=640&amp;q=75 1x, /_next/image?url=%2Fpatient_messaging%2Fsecure-and-compliant-communication.jpg&amp;w=1200&amp;q=75 2x" src="/_next/image?url=%2Fpatient_messaging%2Fsecure-and-compliant-communication.jpg&amp;w=1200&amp;q=75"/></div></div><div class="lg:w-full space-y-8 lg:order-2"><div class="inline-block"><span class="bg-teal-primary/20 text-teal-primary px-4 py-2 rounded-full text-sm font-medium border border-teal-primary/30">تواصل آمن ومتوافق</span></div><div><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-dark mb-6 leading-tight">تواصل آمن ومتوافق</h2><p class="text-xl text-slate-600 leading-relaxed max-w-xl">يجب أن تكون مراسلة المرضى آمنة وخاصة ومتوافقة. على عكس البريد الإلكتروني أو الرسائل النصية أو تطبيقات المستهلكين، التي لا تتوافق مع HIPAA أو GDPR، تضمن هذه الميزة حماية كل تبادل وتخزينه بشكل مسؤول داخل عيادتك الافتراضية.</p></div><div class="grid grid-cols-1 md:grid-cols-2 gap-8"><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield h-6 w-6 text-teal-primary flex-shrink-0 mt-1" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">تشفير شامل</h3><p class="text-slate-600 text-sm">جميع رسائل المرضى والمرفقات وردود مقدمي الرعاية مشفرة أثناء النقل وفي حالة السكون.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-check-big h-6 w-6 text-teal-primary flex-shrink-0 mt-1" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"></path><path d="m9 11 3 3L22 4"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">توافق مع HIPAA وGDPR</h3><p class="text-slate-600 text-sm">مصمم للرعاية الصحية — الاتصالات تلبي أعلى معايير الأمان والخصوصية.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-database h-6 w-6 text-teal-primary flex-shrink-0 mt-1" aria-hidden="true"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M3 5V19A9 3 0 0 0 21 19V5"></path><path d="M3 12A9 3 0 0 0 21 12"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">متكامل مع السجلات الصحية</h3><p class="text-slate-600 text-sm">المحادثات مرتبطة تلقائياً بالسجل الصحي الإلكتروني للمريض، وليست متناثرة عبر تطبيقات غير آمنة.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bell h-6 w-6 text-teal-primary flex-shrink-0 mt-1" aria-hidden="true"><path d="M10.268 21a2 2 0 0 0 3.464 0"></path><path d="M3.262 15.326A1 1 0 0 0 4 17h16a1 1 0 0 0 .74-1.673C19.41 13.956 18 12.499 18 8A6 6 0 0 0 6 8c0 4.499-1.411 5.956-2.738 7.326"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">راحة البال لمقدمي الرعاية والمرضى</h3><p class="text-slate-600 text-sm">أجب على الأسئلة بثقة مع العلم أن التواصل آمن وقابل للمراجعة ومتوافق.</p></div></div></div></div></div></div></div></section><section class="py-16 bg-white"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="text-center mb-12"><div class="inline-block"><span class="bg-blue-vibrant/20 text-blue-vibrant px-4 py-2 rounded-full text-sm font-medium border border-blue-vibrant/30 mb-6">حالات الاستخدام</span></div><h2 class="text-3xl md:text-4xl font-bold text-slate-dark mb-8 mt-4">سيناريوهات مراسلة المرضى الشائعة</h2></div><div class="max-w-5xl mx-auto"><div class="grid grid-cols-1 md:grid-cols-2 gap-8"><div class="bg-white rounded-2xl shadow-lg p-8"><div class="w-16 h-16 mx-auto mb-6 rounded-full bg-green-success/10 flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-square h-8 w-8 text-green-success" aria-hidden="true"><path d="M22 17a2 2 0 0 1-2 2H6.828a2 2 0 0 0-1.414.586l-2.202 2.202A.71.71 0 0 1 2 21.286V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2z"></path></svg></div><h3 class="text-xl font-bold text-slate-dark mb-4 text-center">المتابعات</h3><p class="text-slate-600 text-center leading-relaxed">أسئلة الأدوية، فحوصات التعافي، توضيحات النتائج</p></div><div class="bg-white rounded-2xl shadow-lg p-8"><div class="w-16 h-16 mx-auto mb-6 rounded-full bg-blue-vibrant/10 flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-activity h-8 w-8 text-blue-vibrant" aria-hidden="true"><path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"></path></svg></div><h3 class="text-xl font-bold text-slate-dark mb-4 text-center">الرعاية المزمنة</h3><p class="text-slate-600 text-center leading-relaxed">توجيه مستمر لمرض السكري وارتفاع ضغط الدم والربو</p></div><div class="bg-white rounded-2xl shadow-lg p-8"><div class="w-16 h-16 mx-auto mb-6 rounded-full bg-purple-accent/10 flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text h-8 w-8 text-purple-accent" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path><path d="M14 2v4a2 2 0 0 0 2 2h4"></path><path d="M10 9H8"></path><path d="M16 13H8"></path><path d="M16 17H8"></path></svg></div><h3 class="text-xl font-bold text-slate-dark mb-4 text-center">الآراء الثانية</h3><p class="text-slate-600 text-center leading-relaxed">مراجعة آمنة للتقارير وتقديم توجيه مهني للمرضى الجدد</p></div><div class="bg-white rounded-2xl shadow-lg p-8"><div class="w-16 h-16 mx-auto mb-6 rounded-full bg-teal-primary/10 flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users h-8 w-8 text-teal-primary" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><path d="M16 3.128a4 4 0 0 1 0 7.744"></path><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><circle cx="9" cy="7" r="4"></circle></svg></div><h3 class="text-xl font-bold text-slate-dark mb-4 text-center">الاتصال الأول</h3><p class="text-slate-600 text-center leading-relaxed">بدء علاقات آمنة وموثقة تؤدي إلى استشارات كاملة</p></div></div></div></div></section><section class="py-16 bg-white"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="text-center mb-12"><h2 class="text-3xl md:text-4xl font-bold mb-4">Customer Success Stories</h2><div class="w-24 h-1 bg-blue-vibrant mx-auto"></div></div><div class="grid grid-cols-1 lg:grid-cols-2 gap-8"><div class="bg-white rounded-lg p-8 shadow-lg"><div class="flex flex-col justify-between h-full"><p class="text-gray-700 italic mb-4">&quot;<!-- -->Allowing doctors to offer telemedicine, remote monitoring health plans, collect payments and the health blog are some of the best features of the Virtual Practice®.<!-- -->&quot;</p><div><p class="text-gray-700 font-medium">Dr. Gerard Saltibus MD</p><p class="text-gray-600">General Practitioner, St. Lucia</p></div></div></div><div class="bg-white rounded-lg p-8 shadow-lg"><div class="flex flex-col justify-between h-full"><p class="text-gray-700 italic mb-4">&quot;<!-- -->Virtual Practice platform is delivering next-generation medical care. As a multidisciplinary team, we find it powerful and intuitive for organizing patient cases, with clear medical records that support precise documentation and effective care.<!-- -->&quot;</p><div><p class="text-gray-700 font-medium">Dr. Georgios Leon - Metabolic Specialist</p><p class="text-gray-600">Precision Medicine Startup, Greece</p></div></div></div></div></div></section><script type="application/ld+json">{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is patient messaging in telehealth?","acceptedAnswer":{"@type":"Answer","text":"Patient Messaging is a secure, HIPAA/GDPR-compliant way for patients to send health questions to their provider between visits. Unlike live chat, it's asynchronous — providers respond within defined timeframes, not in real time."}},{"@type":"Question","name":"Why should my clinic use secure patient messaging instead of SMS or WhatsApp?","acceptedAnswer":{"@type":"Answer","text":"SMS and consumer apps aren't secure, compliant, or integrated into your workflow. Secure patient messaging keeps communication encrypted, linked to each patient's health record, and billable — so providers are fairly compensated for their time."}},{"@type":"Question","name":"Can providers bill for patient messages?","acceptedAnswer":{"@type":"Answer","text":"Yes. Patient Messaging can be configured as a billable service with provider-specific pricing. Bills are auto-generated, patients pay online, and funds are transferred directly to your clinic's account. You can also configure follow-up notes within each encounter."}},{"@type":"Question","name":"How does patient messaging integrate with the health record?","acceptedAnswer":{"@type":"Answer","text":"Every question and response is stored in the patient's health record, alongside their health tracker data, labs, and consultations. Providers can schedule appointments, create documents, or assign care plans based on the perspective from a message thread."}},{"@type":"Question","name":"Is this feature useful for second opinions?","acceptedAnswer":{"@type":"Answer","text":"Yes. Patient Messaging is ideal for patients seeking second opinions or initial guidance. New patients submitting questions through your portal are seamlessly onboarded as registered patients in your Virtual Practice."}},{"@type":"Question","name":"How do notifications work for patient messaging?","acceptedAnswer":{"@type":"Answer","text":"Automated notifications are sent at key points: providers receive alerts when a new question arrives, and patients are notified when a response is ready. Notifications can be delivered by email, SMS, or app push."}},{"@type":"Question","name":"Can patients attach reports or images to their questions?","acceptedAnswer":{"@type":"Answer","text":"Yes. Patients can include lab results, medical reports, or photos with their messages, giving providers richer context when responding."}},{"@type":"Question","name":"How does patient messaging help prevent patients from relying only on AI tools?","acceptedAnswer":{"@type":"Answer","text":"When patients don't have easy access to their providers, they often turn to search engines or AI tools for answers. Patient Messaging ensures they can reach their own doctor directly — securely, professionally, and with full context from their health record."}},{"@type":"Question","name":"Is patient messaging only for established patients?","acceptedAnswer":{"@type":"Answer","text":"No. It's valuable both for existing patients (follow-ups, chronic care, medication questions) and for new patients (initial contact, second opinions). It helps providers grow their patient base while improving continuity of care."}},{"@type":"Question","name":"Does patient messaging save time for providers?","acceptedAnswer":{"@type":"Answer","text":"Yes. Because it's asynchronous, providers can respond on their schedule within set response windows. This avoids interruptions from phone calls or SMS, reduces no-shows, and ensures that time spent answering patient questions is properly compensated."}}]}</script><section class="py-16 bg-gray-50"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="text-center mb-12"><h2 class="text-3xl md:text-4xl font-bold mb-4">Frequently Asked Questions</h2><div class="w-24 h-1 bg-blue-vibrant mx-auto"></div></div><div class="max-w-4xl mx-auto bg-white rounded-lg shadow-lg p-8"><div class="border-b border-gray-200 last:border-b-0"><button aria-label="What is patient messaging in telehealth?" class="w-full text-left py-4 flex justify-between items-center hover:text-blue-vibrant transition-colors"><span class="font-medium">What is patient messaging in telehealth?</span><span class="transform transition-transform ">▼</span></button></div><div class="border-b border-gray-200 last:border-b-0"><button aria-label="Why should my clinic use secure patient messaging instead of SMS or WhatsApp?" class="w-full text-left py-4 flex justify-between items-center hover:text-blue-vibrant transition-colors"><span class="font-medium">Why should my clinic use secure patient messaging instead of SMS or WhatsApp?</span><span class="transform transition-transform ">▼</span></button></div><div class="border-b border-gray-200 last:border-b-0"><button aria-label="Can providers bill for patient messages?" class="w-full text-left py-4 flex justify-between items-center hover:text-blue-vibrant transition-colors"><span class="font-medium">Can providers bill for patient messages?</span><span class="transform transition-transform ">▼</span></button></div><div class="border-b border-gray-200 last:border-b-0"><button aria-label="How does patient messaging integrate with the health record?" class="w-full text-left py-4 flex justify-between items-center hover:text-blue-vibrant transition-colors"><span class="font-medium">How does patient messaging integrate with the health record?</span><span class="transform transition-transform ">▼</span></button></div><div class="border-b border-gray-200 last:border-b-0"><button aria-label="Is this featur