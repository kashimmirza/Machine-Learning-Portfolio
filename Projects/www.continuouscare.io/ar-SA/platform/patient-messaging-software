يد وعرض السجلات ودفع الفواتير ومزامنة البيانات الصحية من Apple Health أو Google Health Connect أو الأجهزة المدعومة.\"},{\"title\":\"البقاء على اتصال\",\"description\":\"يتلقى المرضى إشعارات فورية للمواعيد ونتائج المختبر وتحديثات خطة الرعاية — لإبقائهم متفاعلين مع عيادتك بين الزيارات.\"}]},\"cta_section\":{\"title\":\"هل أنت مستعد لمنح المرضى تجربة الجوال التي يتوقعونها؟\",\"subtitle\":\"حوّل الحضور الرقمي لعيادتك مع العيادة الافتراضية — بما في ذلك بوابة الويب للمرضى وتطبيقات الجوال.\",\"trial_title\":\"ابدأ تجربتك المجانية لمدة 14 يوماً للعيادة الافتراضية\",\"trial_description\":\"لا حاجة لبطاقة ائتمان • وصول كامل • إلغاء في أي وقت\",\"button_text\":\"ابدأ التجربة المجانية\"}},\"messaging\":{\"meta\":{\"title\":\"برنامج مراسلة المرضى - ContinuousCare | حلول الرعاية الصحية\",\"description\":\"برنامج مراسلة مرضى احترافي مع تواصل آمن وتذكيرات تلقائية وإشعارات المواعيد وتكامل سلس مع السجل الصحي الإلكتروني للممارسات الصحية.\"},\"hero\":{\"title_prefix\":\"برنامج مراسلة المرضى:\",\"title_highlight\":\"تواصل صحي آمن\",\"subtitle\":\"أجب على الأسئلة بين الزيارات، وأدر المتابعات، وقدم رأياً ثانياً — بشكل آمن وحسب جدولك، متكامل بالكامل مع عيادتك الافتراضية.\",\"benefits\":[\"تواصل متوافق مع HIPAA وGDPR\",\"يحدد مقدمو الرعاية نوافذ الرد — وليس دردشة على مدار الساعة\",\"يمكن للمرضى إرفاق التقارير أو الصور أو الملاحظات\",\"يدعم المتابعات والرعاية المزمنة والآراء الثانية\"]},\"problem_section\":{\"title\":\"لماذا تختار مراسلة المرضى الآمنة؟\",\"subtitle\":\"حوّل طريقة تواصلك مع المرضى بين الزيارات بمراسلة احترافية وآمنة تقوي العلاقات وتحسن نتائج الرعاية.\",\"points\":[{\"title\":\"وصول سهل لمقدمي رعاية موثوقين\",\"description\":\"يمكن للمرضى طرح الأسئلة مباشرة بدلاً من اللجوء فقط إلى الذكاء الاصطناعي أو محركات البحث.\"},{\"title\":\"تواصل آمن واحترافي\",\"description\":\"يبقي المناقشات الصحية بعيداً عن الرسائل القصيرة أو واتساب أو البريد الإلكتروني.\"},{\"title\":\"علاقات أقوى مع المرضى\",\"description\":\"يبني الثقة واستمرارية الرعاية بين الزيارات.\"},{\"title\":\"تحكم مقدم الرعاية\",\"description\":\"أنت تقرر نوافذ الرد، مما يضمن بقاء التواصل قابلاً للإدارة.\"}]},\"async_section\":{\"badge\":\"مراسلة الصحة عن بُعد غير المتزامنة\",\"title\":\"مراسلة الصحة عن بُعد غير المتزامنة\",\"subtitle\":\"نظام مراسلة مرضى آمن حيث يقدم المرضى الأسئلة مع السياق، ويرد مقدمو الرعاية ضمن نوافذ رد محددة — رعاية منظمة، وليس دردشة فورية.\",\"features\":[{\"title\":\"تقديم أسئلة المريض\",\"description\":\"يرسل المرضى أسئلة صحية عبر البوابة أو التطبيق، مع خيار إرفاق التقارير أو الصور.\"},{\"title\":\"نظام رد مقدم الرعاية\",\"description\":\"يرد مقدمو الرعاية حسب جدولهم ضمن أطر زمنية محددة، مما يحافظ على كفاءة الرعاية وقابليتها للإدارة.\"},{\"title\":\"سير عمل متكامل\",\"description\":\"جميع الأسئلة والأجوبة مخزنة في السجل الصحي للمريض، لدعم استمرارية الرعاية.\"},{\"title\":\"لوحة إدارة الأسئلة\",\"description\":\"يتتبع مقدمو الرعاية والفرق أسئلة المرضى ويحددون الأولويات ويديرونها في عرض منظم واحد.\"}]},\"payments_section\":{\"badge\":\"مدفوعات متكاملة\",\"title\":\"مدفوعات متكاملة لمراسلة المرضى\",\"subtitle\":\"حوّل وقت مقدم الرعاية إلى رعاية معوضة — كل لقاء مراسلة يمكن إصدار فاتورة به وتتبعه ودفعه من خلال عيادتك الافتراضية.\",\"features\":[{\"title\":\"تسعير لكل مقدم رعاية\",\"description\":\"حدد رسوم خدمة مختلفة لكل مقدم رعاية، بناءً على دوره أو تخصصه.\"},{\"title\":\"فوترة ومدفوعات تلقائية\",\"description\":\"يتم إنشاء الفواتير تلقائياً للقاءات المراسلة. يدفع المرضى بشكل آمن عبر الإنترنت، وتذهب الأموال مباشرة إلى حساب عيادتك.\"},{\"title\":\"ملاحظات متابعة قابلة للتكوين\",\"description\":\"اسمح بعدد محدد من ردود المتابعة ليتم تضمينها في رسوم لقاء واحد. يمكن إصدار فواتير منفصلة للملاحظات الإضافية إذا لزم الأمر.\"},{\"title\":\"قيمة عادلة لوقت مقدم الرعاية\",\"description\":\"لا مزيد من المكالمات أو الرسائل النصية أو رسائل واتساب غير المدفوعة. يتم تعويض وقت مقدم الرعاية بشكل صحيح من خلال المراسلة المنظمة القابلة للفوترة.\"}]},\"workflow_section\":{\"badge\":\"سير عمل العيادة المتكامل\",\"title\":\"سير عمل العيادة المتكامل\",\"subtitle\":\"مراسلة المرضى ليست أداة معزولة — إنها جزء من عيادتك الافتراضية، مما يضمن أن كل رسالة آمنة وسياقية وقابلة للتنفيذ.\",\"features\":[{\"title\":\"ردود غنية بالسياق\",\"description\":\"يرد مقدمو الرعاية بسياق كامل من السجل الصحي للمريض، بما في ذلك بيانات متتبع الصحة والاستشارات السابقة.\"},{\"title\":\"سجل دائم\",\"description\":\"يتم حفظ الأسئلة والردود في سجل المريض للرجوع إليها في المستقبل ولاستمرارية الرعاية.\"},{\"title\":\"سير عمل قابل للتنفيذ\",\"description\":\"من أي رسالة، يمكن لمقدمي الرعاية جدولة موعد أو إضافة وثيقة استشارة أو وصف دواء أو تعيين المريض لخطة رعاية.\"},{\"title\":\"تسجيل مرضى جدد\",\"description\":\"يتم تسجيل الباحثين عن رأي ثانٍ أو جهات الاتصال لأول مرة بسلاسة كمرضى مسجلين من خلال البوابة.\"},{\"title\":\"إشعارات تلقائية\",\"description\":\"يتم تنبيه مقدمي الرعاية عند وصول أسئلة جديدة؛ ويتم إخطار المرضى عندما تكون الردود جاهزة — عبر البريد الإلكتروني أو الرسائل النصية أو إشعارات التطبيق الفورية.\"},{\"title\":\"فوترة متكاملة\",\"description\":\"كل لقاء يمكن أن ينشئ فاتورة تلقائياً، مع تحصيل المدفوعات عبر الإنترنت وتحويلها مباشرة إلى حساب العيادة.\"}]},\"security_section\":{\"badge\":\"تواصل آمن ومتوافق\",\"title\":\"تواصل آمن ومتوافق\",\"subtitle\":\"يجب أن تكون مراسلة المرضى آمنة وخاصة ومتوافقة. على عكس البريد الإلكتروني أو الرسائل النصية أو تطبيقات المستهلكين، التي لا تتوافق مع HIPAA أو GDPR، تضمن هذه الميزة حماية كل تبادل وتخزينه بشكل مسؤول داخل عيادتك الافتراضية.\",\"features\":[{\"title\":\"تشفير شامل\",\"description\":\"جميع رسائل المرضى والمرفقات وردود مقدمي الرعاية مشفرة أثناء النقل وفي حالة السكون.\"},{\"title\":\"توافق مع HIPAA وGDPR\",\"description\":\"مصمم للرعاية الصحية — الاتصالات تلبي أعلى معايير الأمان والخصوصية.\"},{\"title\":\"متكامل مع السجلات الصحية\",\"description\":\"المحادثات مرتبطة تلقائياً بالسجل الصحي الإلكتروني للمريض، وليست متناثرة عبر تطبيقات غير آمنة.\"},{\"title\":\"راحة البال لمقدمي الرعاية والمرضى\",\"description\":\"أجب على الأسئلة بثقة مع العلم أن التواصل آمن وقابل للمراجعة ومتوافق.\"}]},\"use_cases_section\":{\"badge\":\"حالات الاستخدام\",\"title\":\"سيناريوهات مراسلة المرضى الشائعة\",\"cases\":[{\"title\":\"المتابعات\",\"description\":\"أسئلة الأدوية، فحوصات التعافي، توضيحات النتائج\"},{\"title\":\"الرعاية المزمنة\",\"description\":\"توجيه مستمر لمرض السكري وارتفاع ضغط الدم والربو\"},{\"title\":\"الآراء الثانية\",\"description\":\"مراجعة آمنة للتقارير وتقديم توجيه مهني للمرضى الجدد\"},{\"title\":\"الاتصال الأول\",\"description\":\"بدء علاقات آمنة وموثقة تؤدي إلى استشارات كاملة\"}]},\"final_cta_section\":{\"title\":\"هل أنت مستعد لإطلاق مراسلة المرضى للصحة عن بُعد غير المتزامنة؟\",\"subtitle\":\"ابدأ بتقديم مراسلة مرضى متوافقة مع HIPAA مع مدفوعات متكاملة تتيح للمرضى طرح الأسئلة بسهولة ولمقدمي الرعاية الرد بكفاءة.\",\"button_text\":\"ابدأ التجربة المجانية اليوم\",\"bottom_title\":\"منصة مراسلة صحة عن بُعد غير متزامنة كاملة مضمنة في جميع خطط ContinuousCare\",\"bottom_description\":\"معالجة دفع متقدمة، تسعير خاص بمقدم الرعاية، توافق HIPAA، وتطبيقات جوال أصلية - كلها جاهزة للاستخدام فوراً.\"},\"cta_section\":{\"title\":\"هل أنت مستعد لتحويل رسائل المرضى إلى إيرادات؟\",\"subtitle\":\"حوّل تواصل مرضاك إلى خدمة صحة عن بُعد مربحة بينما تقدم الوصول المريح الذي يتوقعه المرضى.\",\"description_title\":\"حل مراسلة مرضى كامل مضمن في جميع الخطط\",\"description_text\":\"مراسلة صحة عن بُعد غير متزامنة، معالجة دفع، توافق HIPAA، وصول عبر الجوال، وتحسين الإيرادات - كل ما تحتاجه للتواصل المربح مع المرضى.\"}},\"notifications\":{\"meta\":{\"title\":\"إشعارات المرضى - ContinuousCare | منصة الرعاية الصحية\",\"description\":\"نظام إشعارات وتواصل تلقائي للمرضى مدعوم من منصة الرعاية الصحية ContinuousCare.\",\"og_title\":\"إشعارات المرضى - ContinuousCare\",\"og_description\":\"نظام إشعارات وتواصل تلقائي للمرضى\"},\"structured_data\":{\"page_title\":\"نظام إشعارات الرعاية الصحية | العيادة الافتراضية من ContinuousCare\",\"page_description\":\"تذكيرات تلقائية للمواعيد، تنبيهات الفوترة وإشعارات مرضى مخصصة عبر البريد الإلكتروني والرسائل النصية والإشعارات الفورية وواتساب. آمنة ومتوافقة مع HIPAA ومدمجة.\",\"keywords\":\"إشعارات الرعاية الصحية، إشعارات المرضى، تذكيرات المواعيد، تنبيهات الرسائل النصية، إشعارات البريد الإلكتروني، إشعارات متوافقة مع HIPAA، عيادة افتراضية، continuouscare\",\"og_title\":\"نظام إشعارات الرعاية الصحية | العيادة الافتراضية من ContinuousCare\",\"og_description\":\"تذكيرات تلقائية للمواعيد، تنبيهات الفوترة وإشعارات مرضى مخصصة عبر البريد الإلكتروني والرسائل النصية والإشعارات الفورية وواتساب. آمنة ومتوافقة مع HIPAA ومدمجة.\",\"twitter_title\":\"نظام إشعارات الرعاية الصحية | العيادة الافتراضية من ContinuousCare\",\"twitter_description\":\"تذكيرات تلقائية للمواعيد، تنبيهات الفوترة وإشعارات مرضى مخصصة عبر البريد الإلكتروني والرسائل النصية والإشعارات الفورية وواتساب. آمنة ومتوافقة مع HIPAA ومدمجة.\",\"product_name\":\"العيادة الافتراضية — الإشعارات\",\"product_description\":\"إشعارات مدمجة ومدفوعة بسير العمل تبقي المرضى على اطلاع عبر البريد الإلكتروني والرسائل النصية والإشعارات الفورية وداخل التطبيق، مع واتساب اختياري للإشعارات المخصصة. لا توجد معلومات صحية محمية/معلومات تعريف شخصية في القنوات الخارجية؛ وصول آمن عبر البوابة/التطبيق.\",\"features\":[\"إشعارات نظام تلقائية للمواعيد والفوترة وتوفر المختبر/المستندات وتذكيرات خطة الرعاية\",\"إشعارات مخصصة لرسائل العيادة المخصصة\",\"تسليم متعدد القنوات: البريد الإلكتروني، الرسائل النصية (عبر بوابتك)، الإشعارات الفورية على الجوال، داخل التطبيق\",\"واتساب اختياري (عبر واتساب للأعمال) للإشعارات المخصصة فقط\",\"روابط وأزرار قابلة للتنفيذ (تأكيد/إلغاء، الانضمام للصحة عن بُعد، عرض المستندات)\",\"الرسائل الخارجية لا تحتوي على معلومات صحية محمية/معلومات تعريف شخصية؛ يتم الوصول إلى المعلومات الحساسة بعد تسجيل الدخول\",\"يمكن تعطيل إشعارات النظام على مستوى العميل\"]},\"hero\":{\"title\":\"أبقِ المرضى على اطلاع مع\",\"title_highlight\":\"إشعارات رعاية صحية موثوقة\",\"subtitle\":\"قلل حالات عدم الحضور، وحسّن المتابعة، وأبقِ المرضى متصلين مع إشعارات في الوقت المناسب وآمنة تدعم سير عملك.\",\"benefits\":[\"تأكيدات وتذكيرات تلقائية للمواعيد\",\"تنبيهات نتائج المختبر وتوفر المستندات\",\"إشعارات خطة الرعاية والفوترة\",\"إشعارات مخصصة\"],\"image_alt\":\"مريض يتلقى إشعارات على الهاتف الذكي\"},\"problem_section\":{\"title\":\"لماذا تهم الإشعارات في الرعاية الصحية\",\"subtitle\":\"عندما تعتمد العيادات على طرق تواصل محدودة، يضيع المرضى.\",\"problems\":[{\"title\":\"معدلات عالية لعدم الحضور\",\"description\":\"المواعيد الفائتة تكلف وقتاً وإيرادات قيّمة\"},{\"title\":\"البريد الإلكتروني وحده ليس كافياً\",\"description\":\"الرسائل النصية والإشعارات الفورية وداخل التطبيق تزيد من التفاعل.\"},{\"title\":\"حمل زائد على الموظفين\",\"description\":\"تقضي فرق الاستقبال ساعات في إرسال تذكيرات يدوية.\"},{\"title\":\"متابعات مفقودة\",\"description\":\"بدون مطالبات إجراء واضحة، لا يتابع المرضى.\"},{\"title\":\"أدوات منفصلة\",\"description\":\"استخدام أنظمة منفصلة يضيف جهداً على مقدمي الرعاية والمسؤولين.\"},{\"title\":\"مخاطر الامتثال\",\"description\":\"بدون إشعارات آمنة ومتوافقة، قد تتعرض بيانات المرضى الحساسة.\"}]},\"multichannel_delivery\":{\"badge\":\"تسليم متعدد القنوات\",\"title\":\"الوصول إلى المرضى عبر قناتهم المفضلة\",\"subtitle\":\"مدمجة في العيادة الافتراضية، يتم تسليم الإشعارات تلقائياً عبر قنوات آمنة متعددة — دون أدوات إضافية.\",\"features\":[{\"title\":\"إشعارات الرسائل النصية\",\"description\":\"تنبيهات سريعة ومباشرة عبر بوابة الرسائل النصية الخاصة بك.\"},{\"title\":\"تنبيهات البريد الإلكتروني\",\"description\":\"رسائل واضحة ومفصلة بتنسيق غني.\"},{\"title\":\"إشعارات فورية على الجوال\",\"description\":\"تحديثات فورية عبر تطبيق الجوال للمرضى.\"},{\"title\":\"إشعارات داخل التطبيق\",\"description\":\"تنبيهات مركزية داخل بوابة وتطبيق المريض.\"},{\"title\":\"رسائل واتساب (للإشعارات المخصصة فقط)\",\"description\":\"مدعومة عند التكامل مع حساب واتساب للأعمال الخاص بك.\"}],\"image_alt\":\"تسليم إشعارات متعددة القنوات عبر الأجهزة\"},\"workflow_triggers\":{\"badge\":\"محفزات مدفوعة بسير العمل\",\"title\":\"تواصل تلقائي لكل حدث رئيسي\",\"subtitle\":\"يتم إرسال الإشعارات تلقائياً، مدفوعة بالأحداث المهمة في عيادتك.\",\"features\":[{\"title\":\"إشعارات المواعيد\",\"description\":\"تأكيدات وتذكيرات ومتابعات\"},{\"title\":\"تنبيهات المختبر والمستندات\",\"description\":\"إشعارات التوفر مع روابط وصول آمنة.\"},{\"title\":\"دفعات خطة الرعاية\",\"description\":\"تذكيرات لخطوات العلاج أو المراقبة المجدولة.\"},{\"title\":\"إشعارات الفوترة\",\"description\":\"تذكيرات الدفع والإيصالات والتأكيدات.\"}],\"image_alt\":\"محفزات إشعارات مدفوعة بسير العمل\"},\"action_oriented\":{\"badge\":\"تفاعل موجه نحو العمل\",\"title\":\"إشعارات يمكن للمرضى التصرف بناءً عليها\",\"subtitle\":\"تجاوز التذكيرات — مكِّن المرضى بإشعارات قابلة للتنفيذ تقلل الاحتكاك وتدفع الإنجاز.\",\"features\":[{\"title\":\"تأكيد بنقرة واحدة\",\"description\":\"أكد أو ألغِ المواعيد فوراً.\"},{\"title\":\"الوصول للصحة عن بُعد\",\"description\":\"روابط \\\"الانضمام للجلسة\\\" مدمجة في التذكيرات.\"},{\"title\":\"الوصول الآمن للمستندات\",\"description\":\"روابط مباشرة لعرض التقارير أو النتائج بعد تسجيل الدخول.\"},{\"title\":\"خيارات رد سريعة\",\"description\":\"أزرار رد محددة مسبقاً لتفاعل مريض أسرع.\"}],\"image_alt\":\"إشعارات تفاعل مرضى موجهة نحو العمل\"},\"platform_advantages\":{\"title\":\"مدمجة وليست مضافة: لماذا تعمل الإشعارات المتكاملة بشكل أفضل\",\"deep_integration\":{\"title\":\"تكامل عميق مع المنصة\",\"features\":[{\"title\":\"منصة موحدة\",\"description\":\"لا حاجة لمزامنة طرف ثالث أو أدوات إضافية.\"},{\"title\":\"على العلامة التجارية ومتوافقة\",\"description\":\"الرسائل المرسلة عبر قنواتك الخاصة، دائماً بدون معلومات صحية محمية/معلومات تعريف شخصية في البريد الإلكتروني أو الرسائل النصية أو الإشعارات الفورية الخارجية.\"},{\"title\":\"سير عمل سلس\",\"description\":\"يعمل بسلاسة مع الجدولة والفوترة والسجلات وخطط الرعاية.\"}]},\"vs_generic_tools\":{\"title\":\"مقابل الأدوات العامة\",\"features\":[\"مصمم خصيصاً للرعاية الصحية\",\"متوافق مع HIPAA بشكل افتراضي\",\"يدعم إجراءات المرضى الفورية (مثل إعادة الجدولة، الانضمام للجلسة، التأكيد).\",\"قوالب متوافقة مع سير عمل الرعاية الصحية.\"]},\"vs_manual_processes\":{\"title\":\"مقابل العمليات اليدوية\",\"features\":[\"تقليل عبء مكتب الاستقبال\",\"القضاء على الأخطاء والتنبيهات الفائتة\",\"تتبع تفاعلات المرضى وإكمال المتابعة.\",\"تواصل متسق عبر جميع نقاط الاتصال.\",\"تصعيد تلقائي للمرضى غير المستجيبين.\"]}},\"customer_stories\":[{\"quote\":\"أستخدم منصة الرعاية المستمرة منذ عدة أشهر وأحدثت تأثيراً كبيراً في عيادتي مما سمح لي بمراقبة مرضاي بشكل أكثر كفاءة.\",\"author\":\"د. ماري كريستينا فيليكس دويون\",\"role\":\"أخصائية أمراض رئوية، هايتي\"},{\"quote\":\"السماح للأطباء بتقديم الطب عن بُعد، خطط المراقبة الصحية عن بُعد، تحصيل المدفوعات ومدونة الصحة هي بعض من أفضل ميزات العيادة الافتراضية®.\",\"author\":\"د. جيرارد سالتيبوس\",\"role\":\"طبيب عام، سانت لوسيا\"}],\"faqs\":[{\"question\":\"ما أنواع الإشعارات التي تدعمها العيادة الافتراضية؟\",\"answer\":\"تدعم العيادة الافتراضية كلاً من إشعارات النظام التلقائية والإشعارات المخصصة. يتم تشغيل الإشعارات التلقائية بواسطة أحداث مثل المواعيد والفوترة ونتائج المختبر وتذكيرات خطة الرعاية. تسمح الإشعارات المخصصة للعيادات بإرسال رسائلها الخاصة للمرضى. يمكن تسليم الإشعارات عبر البريد الإلكتروني والرسائل النصية (عبر بوابتك الخاصة) والإشعارات الفورية على الجوال والتنبيهات داخل التطبيق، و— إذا كنت تتكامل مع واتساب للأعمال — للإشعارات المخصصة.\"},{\"question\":\"هل يمكنني إيقاف إشعارات النظام إذا كانت عيادتي لا تريدها؟\",\"answer\":\"نعم. الإشعارات التلقائية قابلة للتكوين. إذا كانت عيادتك تفضل عدم إرسال أنواع معينة من التنبيهات، فيمكنك إيقافها على مستوى النظام.\"},{\"question\":\"هل الإشعارات آمنة ومتوافقة مع HIPAA؟\",\"answer\":\"نعم. الإشعارات المرسلة عبر القنوات الخارجية مثل البريد الإلكتروني أو الرسائل النصية أو الإشعارات الفورية لا تتضمن أبداً معلومات تعريف شخصية أو معلومات صحية محمية. يتلقى المرضى روابط لتسجيل الدخول إلى البوابة الآمنة أو تطبيق الجوال لعرض التفاصيل الحساسة. هذا يضمن التوافق الكامل مع لوائح خصوصية الرعاية الصحية.\"},{\"question\":\"هل يمكن للمرضى الرد على الإشعارات؟\",\"answer\":\"نعم. يمكن أن تكون الإشعارات تفاعلية. على سبيل المثال، يمكن للمرضى تأكيد أو إلغاء المواعيد بنقرة واحدة، أو الانضمام لجلسات الصحة عن بُعد مباشرة من التذكير، أو الوصول بشكل آمن إلى نتائج المختبر والمستندات من خلال الروابط المدمجة. يمكن للعيادات أيضاً تكوين أزرار رد سريعة للإجراءات الشائعة.\"},{\"question\":\"هل يدعم النظام واتساب لتواصل المرضى؟\",\"answer\":\"نعم. يمكن استخدام واتساب كقناة إشعارات إذا كانت عيادتك تتكامل مع حساب واتساب للأعمال الخاص بها. ومع ذلك، واتساب متاح فقط للإشعارات المخصصة وليس للتنبيهات التلقائية للنظام.\"},{\"question\":\"كيف يتم تشغيل الإشعارات في النظام؟\",\"answer\":\"الإشعارات مدفوعة بسير العمل ويتم إرسالها تلقائياً عند حدوث أحداث معينة في العيادة الافتراضية. المحفزات الشائعة تشمل حجز المواعيد وتأكيدات الدفع وتوفر نتائج المختبر ومستندات الاستشارة الجديدة وخطوات خطة الرعاية.\"},{\"question\":\"هل يمكن للموظفين إرسال إشعارات يدوية عند الحاجة؟\",\"answer\":\"نعم. بالإضافة إلى سير العمل التلقائي، يمكن للموظفين المصرح لهم إرسال إشعارات مخصصة للمرضى عند الحاجة للتواصل اليدوي. يمكن أيضاً تسليمها عبر قنوات متعددة، بما في ذلك واتساب إذا كانت متكاملة.\"},{\"question\":\"هل تساعد الإشعارات في تقليل حالات عدم حضور المرضى؟\",\"answer\":\"بالتأكيد. التذكيرات التلقائية المرسلة عبر الرسائل النصية والإشعارات الفورية والتنبيهات داخل التطبيق تقلل بشكل كبير من المواعيد الفائتة. الإشعارات القابلة للتنفيذ مع روابط التأكيد تسهل على المرضى الرد أو إعادة الجدولة أو الانضمام لجلسات الصحة عن بُعد — مما يحسن المتابعة الإجمالية.\"},{\"question\":\"كيف تختلف الإشعارات عن استخدام أدوات عامة مثل منصات التسويق عبر البريد الإلكتروني؟\",\"answer\":\"على عكس أدوات المراسلة العامة، إشعارات العيادة الافتراضية مدمجة مباشرة في سير العمل السريري. إنها خاصة بالرعاية الصحية ومتوافقة بشكل افتراضي ومرتبطة بإجراءات المرضى (مثل إعادة الجدولة أو عرض المستندات). لا تحتاج العيادات لإدارة أدوات منفصلة أو مزامنة البيانات.\"},{\"question\":\"هل يمكن تخصيص الإشعارات لتعكس علامة عيادتي التجارية؟\",\"answer\":\"نعم. يتم إرسال الإشعارات من خلال نطاق البريد الإلكتروني المكوّن لعيادتك وبوابة الرسائل النصية وحساب واتساب للأعمال الاختياري. هذا يضمن تواصلاً متسقاً على العلامة التجارية يتعرف عليه المرضى ويثقون به.\"}],\"cta_section\":{\"title\":\"ابدأ بإرسال إشعارات تعمل فعلاً\",\"subtitle\":\"قوِّ كل خطوة من رحلة المريض بتوا