l shadow-2xl w-full object-cover aspect-4/3" style="color:transparent" srcSet="/_next/image?url=%2Fpatient-administration%2Fbanner.jpg&amp;w=828&amp;q=75 1x, /_next/image?url=%2Fpatient-administration%2Fbanner.jpg&amp;w=1920&amp;q=75 2x" src="/_next/image?url=%2Fpatient-administration%2Fbanner.jpg&amp;w=1920&amp;q=75"/></div></div></div></div></section><section class="py-16 bg-white"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="transition-all duration-700 opacity-0 translate-y-10"><div class="text-center mb-16"><h2 class="text-3xl md:text-4xl font-bold mb-6 text-slate-dark">रोगी प्रशासन क्यों मायने रखता है</h2><p class="text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed">केंद्रीकृत रोगी प्रबंधन के साथ अपने क्लिनिक के संचालन को रूपांतरित करें</p></div><div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8"><div class="text-center"><div class="w-16 h-16 bg-blue-vibrant/10 rounded-full flex items-center justify-center mx-auto mb-4"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield h-8 w-8 text-blue-vibrant" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path></svg></div><h3 class="text-xl font-semibold text-slate-dark mb-3">सुव्यवस्थित पंजीकरण</h3><p class="text-slate-600">रोगी अपनी यात्रा से पहले ऑनलाइन पंजीकरण पूरा करते हैं, प्रतीक्षा समय और प्रशासनिक बोझ को कम करते हैं।</p></div><div class="text-center"><div class="w-16 h-16 bg-blue-vibrant/10 rounded-full flex items-center justify-center mx-auto mb-4"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text h-8 w-8 text-blue-vibrant" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path><path d="M14 2v4a2 2 0 0 0 2 2h4"></path><path d="M10 9H8"></path><path d="M16 13H8"></path><path d="M16 17H8"></path></svg></div><h3 class="text-xl font-semibold text-slate-dark mb-3">स्वचालित वर्कफ़्लो</h3><p class="text-slate-600">नियुक्ति रिमाइंडर से लेकर बिलिंग सूचनाओं तक, रोगी देखभाल पर ध्यान केंद्रित करने के लिए नियमित कार्यों को स्वचालित करें।</p></div><div class="text-center"><div class="w-16 h-16 bg-blue-vibrant/10 rounded-full flex items-center justify-center mx-auto mb-4"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bell h-8 w-8 text-blue-vibrant" aria-hidden="true"><path d="M10.268 21a2 2 0 0 0 3.464 0"></path><path d="M3.262 15.326A1 1 0 0 0 4 17h16a1 1 0 0 0 .74-1.673C19.41 13.956 18 12.499 18 8A6 6 0 0 0 6 8c0 4.499-1.411 5.956-2.738 7.326"></path></svg></div><h3 class="text-xl font-semibold text-slate-dark mb-3">केंद्रीकृत रिकॉर्ड</h3><p class="text-slate-600">सभी रोगी जानकारी, यात्रा इतिहास, और संचार एक सुलभ स्थान में सुरक्षित रूप से संग्रहीत।</p></div><div class="text-center"><div class="w-16 h-16 bg-blue-vibrant/10 rounded-full flex items-center justify-center mx-auto mb-4"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-thumbs-up h-8 w-8 text-blue-vibrant" aria-hidden="true"><path d="M7 10v12"></path><path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2a3.13 3.13 0 0 1 3 3.88Z"></path></svg></div><h3 class="text-xl font-semibold text-slate-dark mb-3">बेहतर अनुपालन</h3><p class="text-slate-600">अंतर्निहित HIPAA और GDPR अनुपालन सुविधाएं रोगी डेटा सुरक्षा और नियामक पालन सुनिश्चित करती हैं।</p></div></div></div></div></section><section class="py-16 bg-white"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center transition-all duration-700 opacity-0 translate-y-10"><div class="lg:w-full space-y-8"><div><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-dark mb-6 leading-tight">सुरक्षित और अनुपालन रोगी ऑन-बोर्डिंग</h2><p class="text-xl text-slate-600 leading-relaxed max-w-xl">उच्चतम सुरक्षा मानकों को बनाए रखते हुए रोगी पंजीकरण को सरल बनाएं</p></div><div class="grid grid-cols-1 md:grid-cols-2 gap-8"><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-check-big h-6 w-6 text-blue-vibrant flex-shrink-0 mt-1" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"></path><path d="m9 11 3 3L22 4"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">डिजिटल पंजीकरण फॉर्म</h3><p class="text-slate-600 text-sm">अनुकूलन योग्य ऑनलाइन फॉर्म जो रोगी जानकारी, चिकित्सा इतिहास और बीमा विवरण सुरक्षित रूप से एकत्र करते हैं।</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-check-big h-6 w-6 text-blue-vibrant flex-shrink-0 mt-1" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"></path><path d="m9 11 3 3L22 4"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">सहमति प्रबंधन</h3><p class="text-slate-600 text-sm">पूर्ण ऑडिट ट्रेल्स के साथ उपचार, डेटा साझाकरण और संचार के लिए डिजिटल सहमति कैप्चर और स्टोर करें।</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-check-big h-6 w-6 text-blue-vibrant flex-shrink-0 mt-1" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"></path><path d="m9 11 3 3L22 4"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">पहचान सत्यापन</h3><p class="text-slate-600 text-sm">बहु-कारक प्रमाणीकरण और सत्यापन प्रक्रियाएं रोगी पहचान सुनिश्चित करती हैं और धोखाधड़ी को रोकती हैं।</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-check-big h-6 w-6 text-blue-vibrant flex-shrink-0 mt-1" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"></path><path d="m9 11 3 3L22 4"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">बीमा सत्यापन</h3><p class="text-slate-600 text-sm">स्वचालित बीमा सत्यापन और पात्रता जांच दावे की अस्वीकृति और बिलिंग समस्याओं को कम करती है।</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-check-big h-6 w-6 text-blue-vibrant flex-shrink-0 mt-1" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"></path><path d="m9 11 3 3L22 4"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">दस्तावेज़ अपलोड</h3><p class="text-slate-600 text-sm">बीमा कार्ड, पहचान और चिकित्सा रिकॉर्ड के लिए सुरक्षित दस्तावेज़ अपलोड।</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-check-big h-6 w-6 text-blue-vibrant flex-shrink-0 mt-1" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"></path><path d="m9 11 3 3L22 4"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">अनुपालन ट्रैकिंग</h3><p class="text-slate-600 text-sm">स्वचालित अनुपालन जांच सुनिश्चित करती है कि नियुक्तियों से पहले सभी आवश्यक जानकारी एकत्र की गई है।</p></div></div></div></div></div><div class="lg:w-full"><div class="relative"><img alt="रोगी मोबाइल डिवाइस पर सुरक्षित ऑनलाइन पंजीकरण पूरा कर रहा है" loading="lazy" width="800" height="600" decoding="async" data-nimg="1" class="rounded-2xl shadow-2xl w-full object-cover aspect-4/3" style="color:transparent" srcSet="/_next/image?url=%2Fpatient-administration%2Fpatient-administration-software.png&amp;w=828&amp;q=75 1x, /_next/image?url=%2Fpatient-administration%2Fpatient-administration-software.png&amp;w=1920&amp;q=75 2x" src="/_next/image?url=%2Fpatient-administration%2Fpatient-administration-software.png&amp;w=1920&amp;q=75"/></div></div></div></div></section><section class="py-16 bg-gray-50"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center transition-all duration-700 opacity-0 translate-y-10"><div class="lg:w-full"><div class="relative"><img alt="स्वास्थ्य स्टाफ व्यापक रोगी प्रबंधन डैशबोर्ड तक पहुंच रहा है" loading="lazy" width="800" height="600" decoding="async" data-nimg="1" class="rounded-2xl shadow-2xl w-full object-cover aspect-4/3" style="color:transparent" srcSet="/_next/image?url=%2Fpatient-administration%2Fdigital-patient-management-for-clinics.png&amp;w=828&amp;q=75 1x, /_next/image?url=%2Fpatient-administration%2Fdigital-patient-management-for-clinics.png&amp;w=1920&amp;q=75 2x" src="/_next/image?url=%2Fpatient-administration%2Fdigital-patient-management-for-clinics.png&amp;w=1920&amp;q=75"/></div></div><div class="lg:w-full space-y-8"><div><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-dark mb-6 leading-tight">व्यापक रोगी प्रशासन</h2><p class="text-xl text-slate-600 leading-relaxed max-w-xl">एक एकीकृत प्लेटफ़ॉर्म में रोगियों को कुशलतापूर्वक प्रबंधित करने के लिए आवश्यक सब कुछ</p></div><div class="grid grid-cols-1 md:grid-cols-2 gap-8"><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-check-big h-6 w-6 text-blue-vibrant flex-shrink-0 mt-1" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"></path><path d="m9 11 3 3L22 4"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">रोगी जनसांख्यिकी</h3><p class="text-slate-600 text-sm">संपर्क जानकारी, आपातकालीन संपर्कों और जनसांख्यिकीय डेटा के साथ पूर्ण रोगी प्रोफ़ाइल।</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-check-big h-6 w-6 text-blue-vibrant flex-shrink-0 mt-1" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"></path><path d="m9 11 3 3L22 4"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">चिकित्सा इतिहास</h3><p class="text-slate-600 text-sm">एलर्जी, दवाओं और पिछले उपचारों सहित व्यापक चिकित्सा इतिहास ट्रैकिंग।</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-check-big h-6 w-6 text-blue-vibrant flex-shrink-0 mt-1" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 