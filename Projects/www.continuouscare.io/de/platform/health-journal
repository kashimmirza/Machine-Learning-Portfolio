\":{\"title\":\"Plattform\",\"links\":{\"features\":\"Funktionen\",\"security\":\"Sicherheit\",\"integrations\":\"Integrationen\",\"api\":\"API\"}},\"company\":{\"title\":\"Unternehmen\",\"links\":{\"about\":\"Über Uns\",\"careers\":\"Karriere\",\"blog\":\"Blog\",\"contact\":\"Kontakt\"}},\"support\":{\"title\":\"Support\",\"links\":{\"help_center\":\"Hilfezentrum\",\"training\":\"Schulung\",\"status\":\"Status\",\"community\":\"Community\"}},\"legal\":{\"title\":\"Rechtliches\",\"links\":{\"privacy\":\"Datenschutz\",\"terms\":\"Bedingungen\",\"hipaa\":\"HIPAA\",\"security\":\"Sicherheit\",\"responsible_disclosure\":\"Verantwortungsvolle Offenlegung\"}}}}},\"health-features\":{\"health_trackers\":{\"meta\":{\"title\":\"Health Trackers Integrated with EHR | Remote Monitoring \u0026 Patient Engagement\",\"description\":\"Track 70+ health metrics from vitals to lifestyle. Data from patients, providers, devices, Apple Health, and Google Health Connect flows into the EHR — powering Remote Patient Monitoring, consultations, and AI-assisted documentation.\",\"keywords\":\"health trackers,EHR health monitoring,patient health data,connected devices,health metrics tracking,remote patient monitoring,AI scribe integration,healthcare data management\"},\"structured_data\":{\"faq_page\":{\"questions\":[{\"question\":\"What are Health Trackers in the Virtual Practice?\",\"answer\":\"Health Trackers are a library of 70+ parameters—covering vitals, labs and lifestyle—that patients and providers can record. All data is stored in the patient's electronic health record (EHR).\"},{\"question\":\"How do Health Trackers improve care for providers?\",\"answer\":\"They provide a continuous view of patient health between visits, power Remote Patient Monitoring (RPM) care plans, and surface longitudinal trends during consultations.\"},{\"question\":\"Can patients log their own health data?\",\"answer\":\"Yes. Patients can log readings in the portal or mobile app, and also sync data from compatible devices and health apps.\"},{\"question\":\"Which devices and health apps are supported?\",\"answer\":\"Health Trackers connect with Bluetooth-enabled monitors, wearables, and popular platforms like Apple Health (iOS) and Google Health Connect (Android).\"},{\"question\":\"Can providers add measurements during visits?\",\"answer\":\"Yes. Providers can add vitals and other measurements during in-person or telehealth consultations so the EHR stays current.\"},{\"question\":\"How do Health Trackers support Remote Patient Monitoring (RPM)?\",\"answer\":\"Tracker data forms the foundation of RPM care plans. Teams can set personalized thresholds, assign monitoring roles, and receive alerts when values fall outside configured ranges.\"},{\"question\":\"Are patients actively involved with Health Trackers?\",\"answer\":\"Yes. Patients can see their data, track goals, and collaborate with providers through shared monitoring and feedback.\"},{\"question\":\"Do Health Trackers integrate with AI features?\",\"answer\":\"Yes. Tracker data in the EHR provides context for AI Scribe, helping generate richer, more accurate clinical notes.\"},{\"question\":\"Can clinics customize which trackers are available?\",\"answer\":\"Yes. Admins can enable the subset of the 70+ trackers that fits their practice and tailor availability at the patient level.\"},{\"question\":\"Is tracker data secure and compliant?\",\"answer\":\"Yes. All tracker entries are stored securely within the patient's EHR under strict privacy and security controls across web and mobile.\"}]},\"software_application\":{\"name\":\"Health Trackers\",\"alternate_name\":\"EHR Health Trackers\",\"url\":\"https://www.continuouscare.io/health-trackers\",\"description\":\"Track 70+ patient health metrics—vitals, labs, and lifestyle—via manual entry, Bluetooth devices, and health platforms. All data is stored in the patient EHR and powers Remote Patient Monitoring care plans, consultations, trends, and AI-assisted documentation.\",\"features\":[\"70+ configurable health trackers (vitals, labs, lifestyle)\",\"Data entry by patients and providers\",\"Bluetooth device and wearable syncing\",\"Apple Health (iOS) and Google Health Connect (Android) integrations\",\"Trends and longitudinal charts in the EHR\",\"Foundation for RPM care plans (thresholds and alerts)\",\"Consultation-ready context for providers\",\"Context for AI Scribe clinical documentation\"],\"brand_name\":\"ContinuousCare\",\"brand_url\":\"https://www.continuouscare.io\",\"part_of_name\":\"Virtual Practice\",\"part_of_url\":\"https://www.continuouscare.io/virtual-practice\"}},\"hero\":{\"title_prefix\":\"Comprehensive\",\"title_highlight\":\"Health Tracking\",\"title_suffix\":\"for Better Patient Outcomes\",\"subtitle\":\"Empower patients to monitor their health metrics while providing healthcare providers with comprehensive, real-time data for informed care decisions.\",\"benefits\":[\"Multi-device health data integration\",\"Real-time vital signs monitoring\",\"Customizable health goal tracking\",\"Provider dashboard with alerts\"]},\"image_alts\":{\"hero\":\"Healthcare professional monitoring patient health data\",\"comprehensive_monitoring\":\"Comprehensive health monitoring dashboard\",\"clinical_integration\":\"Health trackers integrated into everyday clinical care\",\"device_compatibility\":\"Various health monitoring devices and wearables\",\"specialty_optimization\":\"Medical specialists using specialized monitoring tools\",\"patient_collaboration\":\"Healthcare provider and patient collaborating on health monitoring\"},\"supporting_strip\":{\"vital_signs\":\"Vital Signs\",\"health_conditions\":\"Health Conditions\",\"fitness_wellness\":\"Fitness \u0026 Wellness\",\"blood_tests\":\"Blood Tests\"},\"why_it_matters\":{\"title\":\"Why It Matters\",\"features\":[{\"title\":\"All in the EHR\",\"description\":\"Every tracker entry is stored in the patient's record — no silos.\"},{\"title\":\"Connect Devices \u0026 Apps\",\"description\":\"Patients sync from Apple Health, Google Health Connect, or devices.\"},{\"title\":\"Power RPM Care Plans\",\"description\":\"Tracker data fuels personalized thresholds, alerts, and monitoring.\"},{\"title\":\"Smarter Documentation\",\"description\":\"AI Scribe uses tracker data to generate richer, context-aware notes.\"}]},\"comprehensive_coverage\":{\"badge\":\"Comprehensive Parameter Coverage\",\"title\":\"Complete Health Monitoring\",\"subtitle\":\"Track 70+ health metrics — from vitals to lifestyle — all unified in the patient's EHR, with data flowing in from patients, providers, and devices to support continuous care.\",\"features\":[{\"title\":\"Vital Signs \u0026 Physiological Data\",\"description\":\"Monitor blood pressure, heart rate, SpO₂, weight, temperature, and more with real-time syncing from devices or manual entry.\"},{\"title\":\"Chronic Condition Parameters\",\"description\":\"Track glucose, respiratory rate, and other markers critical for managing diabetes, hypertension, COPD, and cardiac conditions.\"},{\"title\":\"Fitness \u0026 Wellness Metrics\",\"description\":\"Follow activity, sleep, body composition, menstrual cycles, nutrition, and mood to support preventive and holistic care.\"},{\"title\":\"Specialty-Specific Indicators\",\"description\":\"Enable the right subset of trackers for each specialty — from kidney and liver function to women's health — tailored to patient needs.\"}]},\"everyday_care\":{\"badge\":\"Everyday Care Integration\",\"title\":\"Health Trackers in Everyday Care\",\"subtitle\":\"Health Trackers are more than data points — they form the backbone of continuous care inside the Virtual Practice. From powering Remote Patient Monitoring plans to supporting providers during consultations, they ensure patient health information is always actionable.\",\"features\":[{\"title\":\"Foundation for RPM\",\"description\":\"Personalized thresholds and alerts in Remote Patient Monitoring plans are built directly on tracker data.\"},{\"title\":\"Consultation Context\",\"description\":\"Providers can review longitudinal health trends during encounters, add new measurements, and use the information to guide treatment decisions.\"},{\"title\":\"Team-Based Monitoring\",\"description\":\"Assign monitoring responsibilities to a team of providers so patient data never goes unnoticed.\"},{\"title\":\"Smarter Documentation\",\"description\":\"Tracker data is stored in the EHR and referenced by tools like AI Scribe, helping providers create accurate, context-rich notes.\"}]},\"device_connectivity\":{\"badge\":\"Device Connectivity\",\"title\":\"Extensive Device Compatibility\",\"subtitle\":\"Sync health data from multiple sources — Bluetooth-enabled devices, connected wearables, health platforms like Apple Health and Google Health Connect, and even AI-based measurement systems. All data flows into the EHR, ready for use across care plans and consultations.\",\"features\":[{\"title\":\"Third-Party Device Integration\",\"description\":\"Works with a wide range of Bluetooth-enabled monitors and wearables.\"},{\"title\":\"Consumer \u0026 Clinical-Grade Devices\",\"description\":\"Compatible with both everyday health trackers and validated medical equipment.\"},{\"title\":\"Health Platform Integrations\",\"description\":\"Patients can connect their Apple Health (iOS) or Google Health Connect (Android) accounts to share supported metrics.\"},{\"title\":\"Unified EHR Access\",\"description\":\"Synced data is securely stored in the patient's health record and visible to providers wherever needed.\"}]},\"specialty_optimization\":{\"badge\":\"Specialty Optimization\",\"title\":\"Tailored for Real-World Care\",\"subtitle\":\"Health Trackers adapt to the way different disciplines deliver care — from managing long-term conditions to supporting recovery and preventive health.\",\"features\":[{\"title\":\"Chronic Care Management\",\"description\":\"Continuous tracking of glucose, blood pressure, respiratory rate, and other markers for conditions like diabetes, hypertension, and COPD.\"},{\"title\":\"Post-Surgical \u0026 Short-Term Monitoring\",\"description\":\"Track vitals and symptoms during recovery periods, with alerts for early intervention.\"},{\"title\":\"Preventive \u0026 Lifestyle Support\",\"description\":\"Monitor activity, sleep, nutrition, and mood to guide wellness and preventive care plans.\"},{\"title\":\"Consultation-Ready Insights\",\"description\":\"Providers can review longitudinal health data during encounters to inform next steps.\"}]},\"patient_collaboration\":{\"badge\":\"Patient Collaboration\",\"title\":\"Shared Health Monitoring\",\"subtitle\":\"Health Trackers turn patients into active partners in their own care. By logging data, syncing devices, and tracking progress in the patient app, individuals stay engaged — while providers gain the context to guide them more effectively.\",\"features\":[{\"title\":\"Set and Track Goals Together\",\"description\":\"Providers and patients agree on health targets and measure progress collaboratively.\"},{\"title\":\"Ongoing Visibility\",\"description\":\"Patients share updates in real time, so providers can see trends without waiting for the next visit.\"},{\"title\":\"Meaningful Feedback Loops\",\"description\":\"Providers can comment on progress, adjust plans, and celebrate milestones to keep patients motivated.\"},{\"title\":\"Stronger Engagement\",\"description\":\"Patients feel ownership of their data, driving adherence and long-term participation in care plans.\"}]},\"customer_stories\":[{\"quote\":\"Virtual Practice platform is delivering next-generation medical care. As a multidisciplinary team, we find it powerful and intuitive for organizing patient cases, with clear medical records that support precise documentation and effective care.\",\"author\":\"Dr. Georgios Leon - Metabolic Specialist\",\"role\":\"Precision Medicine Startup, Greece\"},{\"quote\":\"It's been an easy, practical and rel