-6 w-6 text-teal-500" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="m15 9-6 6"></path><path d="m9 9 6 6"></path></svg></div></div><div><h3 class="font-bold text-slate-800 mb-2">High No-Show Rates</h3><p class="text-slate-600 text-sm leading-relaxed">Missed appointments cost valuable time and revenue</p></div></div><div class="flex items-start gap-4"><div class="flex-shrink-0"><div class="p-3 bg-teal-100 rounded-full"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-x h-6 w-6 text-teal-500" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="m15 9-6 6"></path><path d="m9 9 6 6"></path></svg></div></div><div><h3 class="font-bold text-slate-800 mb-2">Email Alone Isn&#x27;t Enough</h3><p class="text-slate-600 text-sm leading-relaxed">SMS, push, and in-app notifications drive higher engagement.</p></div></div><div class="flex items-start gap-4"><div class="flex-shrink-0"><div class="p-3 bg-teal-100 rounded-full"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-x h-6 w-6 text-teal-500" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="m15 9-6 6"></path><path d="m9 9 6 6"></path></svg></div></div><div><h3 class="font-bold text-slate-800 mb-2">Staff Overload</h3><p class="text-slate-600 text-sm leading-relaxed">Front desk teams spend hours sending manual reminders.</p></div></div><div class="flex items-start gap-4"><div class="flex-shrink-0"><div class="p-3 bg-teal-100 rounded-full"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-x h-6 w-6 text-teal-500" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="m15 9-6 6"></path><path d="m9 9 6 6"></path></svg></div></div><div><h3 class="font-bold text-slate-800 mb-2">Missed Follow-Ups</h3><p class="text-slate-600 text-sm leading-relaxed">Without clear action prompts, patients don&#x27;t follow through.</p></div></div><div class="flex items-start gap-4"><div class="flex-shrink-0"><div class="p-3 bg-teal-100 rounded-full"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-x h-6 w-6 text-teal-500" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="m15 9-6 6"></path><path d="m9 9 6 6"></path></svg></div></div><div><h3 class="font-bold text-slate-800 mb-2">Disconnected Tools</h3><p class="text-slate-600 text-sm leading-relaxed">Using separate systems adds effort for providers and admins.</p></div></div><div class="flex items-start gap-4"><div class="flex-shrink-0"><div class="p-3 bg-teal-100 rounded-full"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-x h-6 w-6 text-teal-500" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="m15 9-6 6"></path><path d="m9 9 6 6"></path></svg></div></div><div><h3 class="font-bold text-slate-800 mb-2">Compliance Risks</h3><p class="text-slate-600 text-sm leading-relaxed">Without secure, compliant notifications, sensitive patient data may be exposed.</p></div></div></div></div></div></div></div></section><section class="py-16 bg-white"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center transition-all duration-700 opacity-0 translate-y-10"><div class="lg:w-full space-y-8"><div class="inline-block"><span class="bg-blue-light/20 text-blue-vibrant px-4 py-2 rounded-full text-sm font-medium border border-blue-vibrant/30">Multichannel Delivery</span></div><div><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-dark mb-6 leading-tight">Reach Patients on Their Preferred Channel</h2><p class="text-xl text-slate-600 leading-relaxed max-w-xl">Built into the Virtual Practice, notifications are delivered automatically across multiple secure channels—without extra tools.</p></div><div class="grid grid-cols-1 md:grid-cols-2 gap-8"><div class="space-y-4 "><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-square h-6 w-6 text-blue-vibrant flex-shrink-0 mt-1" aria-hidden="true"><path d="M22 17a2 2 0 0 1-2 2H6.828a2 2 0 0 0-1.414.586l-2.202 2.202A.71.71 0 0 1 2 21.286V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2z"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">SMS Notifications</h3><p class="text-slate-600 text-sm">Fast, direct alerts through your own SMS gateway.</p></div></div></div><div class="space-y-4 "><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-mail h-6 w-6 text-blue-vibrant flex-shrink-0 mt-1" aria-hidden="true"><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path><rect x="2" y="4" width="20" height="16" rx="2"></rect></svg><div><h3 class="font-semibold text-slate-800 mb-1">Email Alerts</h3><p class="text-slate-600 text-sm">Clear and detailed messages with rich formatting.</p></div></div></div><div class="space-y-4 "><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bell h-6 w-6 text-blue-vibrant flex-shrink-0 mt-1" aria-hidden="true"><path d="M10.268 21a2 2 0 0 0 3.464 0"></path><path d="M3.262 15.326A1 1 0 0 0 4 17h16a1 1 0 0 0 .74-1.673C19.41 13.956 18 12.499 18 8A6 6 0 0 0 6 8c0 4.499-1.411 5.956-2.738 7.326"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">Mobile Push Notifications</h3><p class="text-slate-600 text-sm">Instant updates through the patient mobile app.</p></div></div></div><div class="space-y-4 "><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bell h-6 w-6 text-blue-vibrant flex-shrink-0 mt-1" aria-hidden="true"><path d="M10.268 21a2 2 0 0 0 3.464 0"></path><path d="M3.262 15.326A1 1 0 0 0 4 17h16a1 1 0 0 0 .74-1.673C19.41 13.956 18 12.499 18 8A6 6 0 0 0 6 8c0 4.499-1.411 5.956-2.738 7.326"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">In-App Notifications</h3><p class="text-slate-600 text-sm">Centralized alerts inside the patient portal and app.</p></div></div></div><div class="space-y-4 md:col-span-2"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-square h-6 w-6 text-blue-vibrant flex-shrink-0 mt-1" aria-hidden="true"><path d="M22 17a2 2 0 0 1-2 2H6.828a2 2 0 0 0-1.414.586l-2.202 2.202A.71.71 0 0 1 2 21.286V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2z"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">WhatsApp Messaging (Custom Notifications only)</h3><p class="text-slate-600 text-sm">Supported when integrated with your WhatsApp Business account.</p></div></div></div></div></div><div class="lg:w-full"><div class="relative"><img alt="Multichannel notification delivery across devices" loading="lazy" width="600" height="450" decoding="async" data-nimg="1" class="rounded-2xl shadow-2xl w-full h-auto max-h-[600px] object-cover" style="color:transparent" srcSet="/_next/image?url=%2Fpatient_notifications%2Fmultichannel_delivery.png&amp;w=640&amp;q=75 1x, /_next/image?url=%2Fpatient_notifications%2Fmultichannel_delivery.png&amp;w=1200&amp;q=75 2x" src="/_next/image?url=%2Fpatient_notifications%2Fmultichannel_delivery.png&amp;w=1200&amp;q=75"/></div></div></div></div></section><section class="py-16 bg-gray-50"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center transition-all duration-700 opacity-0 translate-y-10"><div class="lg:w-full lg:order-1"><div class="relative"><img alt="Workflow-driven notification triggers" loading="lazy" width="600" height="450" decoding="async" data-nimg="1" class="rounded-2xl shadow-2xl w-full h-auto max-h-[600px] object-cover" style="color:transparent" srcSet="/_next/image?url=%2Fpatient_notifications%2Fworkflow_driven_triggers.png&amp;w=640&amp;q=75 1x, /_next/image?url=%2Fpatient_notifications%2Fworkflow_driven_triggers.png&amp;w=1200&amp;q=75 2x" src="/_next/image?url=%2Fpatient_notifications%2Fworkflow_driven_triggers.png&amp;w=1200&amp;q=75"/></div></div><div class="lg:w-full space-y-8 lg:order-2"><div class="inline-block"><span class="bg-green-success/20 text-green-success px-4 py-2 rounded-full text-sm font-medium border border-green-success/30">Workflow-Driven Triggers</span></div><div><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-dark mb-6 leading-tight">Automated Communication for Every Key Event</h2><p class="text-xl text-slate-600 leading-relaxed max-w-xl">Notifications are sent automatically, triggered by the events that matter in your practice.</p></div><div class="grid grid-cols-1 md:grid-cols-2 gap-8"><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar h-6 w-6 text-green-success flex-shrink-0 mt-1" aria-hidden="true"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">Appointment Notifications</h3><p class="text-slate-600 text-sm">Confirmations, reminders, and follow-ups</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text h-6 w-6 text-green-success flex-shrink-0 mt-1" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path><path d="M14 2v4a2 2 0 0 0 2 2h4"></path><path d="M10 9H8"></path><path d="M16 13H8"></path><path d="M16 17H8"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">Lab &amp; Document Alerts</h3><p class="text-slate-600 text-sm">Availability notices with secure access links.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-heart h-6 w-6 text-green-success flex-shrink-0 mt-1" aria-hidden="true"><path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">Care Plan Nudges</h3><p class="text-slate-600 text-sm">Reminders for treatment steps or scheduled monitoring.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-activity h-6 w-6 text-green-success flex-shrink-0 mt-1" aria-hidden="true"><path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">Billing Notifications</h3><p class="text-slate-600 text-sm">Payment reminders, receipts, and confirmations.</p></div></div></div></div></div></div></div></section><section class="py-16 bg-white"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center transition-all duration-700 opacity-0 translate-y-10"><div class="lg:w-full space-y-8"><div class="inline-block"><span class="bg-purple-light/20 text-purple-accent px-4 py-2 rounded-full text-sm font-medium border border-purple-accent/30">Action-Oriented Engagement</span></div><div><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-dark mb-6 leading-tight">Notifications That Patients Can Act On</h2><p class="text-xl text-slate-600 leading-relaxed max-w-xl">Go beyond reminders—empower patients with actionable notifications that reduce friction and drive completion.</p></div><div class="grid grid-cols-1 md:grid-cols-2 gap-8"><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar h-6 w-6 text-purple-accent flex-shrink-0 mt-1" aria-hidden="true"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">One-Tap Confirmation</h3><p class="text-slate-600 text-sm">Confirm or cancel appointments instantly.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-link h-6 w-6 text-purple-accent flex-shrink-0 mt-1" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">Telehealth Access</h3><p class="text-slate-600 text-sm">&quot;Join Session&quot; links embedded in reminders.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text h-6 w-6 text-purple-accent flex-shrink-0 mt-1" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path><path d="M14 2v4a2 2 0 0 0 2 2h4"></path><path d="M10 9H8"></path><path d="M16 13H8"></path><path d="M16 17H8"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">Secure Document Access</h3><p class="text-slate-600 text-sm">Direct links to view reports or results after login.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-zap h-6 w-6 text-purple-accent flex-shrink-0 mt-1" aria-hidden="true"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1