namento\",\"status\":\"Status\",\"community\":\"Comunidade\"}},\"legal\":{\"title\":\"Legal\",\"links\":{\"privacy\":\"Privacidade\",\"terms\":\"Termos\",\"hipaa\":\"HIPAA\",\"security\":\"Segurança\",\"responsible_disclosure\":\"Divulgação Responsável\"}}}}},\"consultations\":{\"video_consultations\":{\"meta\":{\"title\":\"Software de Consulta por Vídeo de Telessaúde - ContinuousCare | Soluções de Saúde\",\"description\":\"Software profissional de consulta por vídeo de telessaúde com chamadas de vídeo HD, salas de espera virtuais, compartilhamento de tela, sessões com múltiplos participantes e integração perfeita com EHR para práticas de saúde.\",\"og_title\":\"Software de Consulta por Vídeo de Telessaúde - ContinuousCare\",\"og_description\":\"Software profissional de consulta por vídeo de telessaúde com chamadas de vídeo HD e integração com EHR\"},\"structured_data\":{\"faq_questions\":[{\"question\":\"Como funcionam as consultas por vídeo de telessaúde no Virtual Practice?\",\"answer\":\"Os pacientes agendam e pagam por consultas por vídeo através do seu portal ou aplicativo móvel. No horário agendado, eles fazem login e entram de forma segura. Os prestadores de serviços veem a consulta em seu calendário, acessam o registro de saúde do paciente durante a chamada, fazem anotações e criam documentos de consulta, prescrições ou pedidos de laboratório depois.\"},{\"question\":\"Os pacientes e prestadores de serviços recebem lembretes sobre consultas por vídeo?\",\"answer\":\"Sim. Lembretes automatizados são enviados para consultas de telemedicina agendadas, pagamentos e acompanhamentos. As notificações podem ser entregues por email, SMS ou push para reduzir ausências e manter todos preparados.\"},{\"question\":\"Os pacientes precisam de aplicativos especiais para consultas de telemedicina?\",\"answer\":\"Não. Os pacientes simplesmente fazem login através do seu portal do paciente com sua marca ou aplicativo móvel. As consultas por vídeo de telessaúde rodam diretamente dentro do Virtual Practice—sem necessidade de downloads de terceiros.\"},{\"question\":\"Posso faturar consultas de telessaúde da mesma forma que consultas presenciais?\",\"answer\":\"Sim. As consultas de telemedicina são definidas como serviços presenciais. Você pode definir duração, taxas de serviço e impostos; os pacientes pagam online; e os registros de faturamento são gerados automaticamente.\"},{\"question\":\"O que acontece com as anotações de uma consulta por vídeo?\",\"answer\":\"As anotações feitas durante a consulta por vídeo são armazenadas no registro do encontro. Os prestadores de serviços podem usá-las para gerar documentos de consulta, prescrições ou pedidos de laboratório. Se o AI Scribe for usado, essas anotações são incluídas como contexto para criar documentação clínica.\"},{\"question\":\"Mais de uma pessoa pode participar de uma chamada de telemedicina?\",\"answer\":\"Sim. Os prestadores de serviços podem convidar cuidadores, tradutores ou participantes adicionais para chamadas de vídeo instantâneas. Um modo de vídeo assistido também permite que enfermeiros ou funcionários ajudem pacientes em áreas remotas a se conectarem com seu prestador de serviços.\"},{\"question\":\"As consultas por vídeo de telessaúde são seguras e conformes?\",\"answer\":\"Sim. Todas as consultas de telemedicina são criptografadas e conformes com HIPAA, GDPR e outras regulamentações de saúde. White-labelling é opcional—você pode manter o visual padrão ou personalizar o portal e aplicativos para refletir sua marca.\"},{\"question\":\"Que equipamento os pacientes precisam para consultas de telessaúde?\",\"answer\":\"Um smartphone, tablet ou computador com câmera e uma conexão de internet confiável é suficiente. Nenhum hardware extra é necessário para a maioria das consultas por vídeo.\"}],\"product\":{\"name\":\"Consultas por Vídeo do Virtual Practice\",\"alternateName\":\"Plataforma de Telessaúde e Telemedicina\",\"brand\":\"ContinuousCare\",\"description\":\"O Virtual Practice da ContinuousCare permite consultas por vídeo seguras de telessaúde e telemedicina para clínicas, pequenas práticas e startups de saúde digital. Os pacientes podem agendar, pagar e participar de consultas online através de aplicativos web ou móveis, enquanto os prestadores de serviços gerenciam agendamento, faturamento e registros de saúde em um sistema integrado.\",\"category\":\"Software de Telessaúde\",\"audience\":\"Profissionais de saúde, Clínicas, Startups de Saúde Digital\",\"keywords\":\"telessaúde, telemedicina, consultas por vídeo, plataforma de cuidados virtuais, SaaS de saúde, cuidados remotos ao paciente\"}},\"hero\":{\"title\":\"Software de Consulta por Vídeo de Telessaúde: \",\"title_highlight\":\"Cuidados Profissionais\",\"title_suffix\":\" em Qualquer Lugar\",\"subtitle\":\"Forneça cuidados através de consultas seguras de telemedicina, totalmente integradas com agendamentos, faturamento e registros de saúde em seu Virtual Practice.\",\"cta_text\":\"Iniciar Teste Gratuito\",\"image_alt\":\"Profissional de saúde realizando consulta por vídeo com AI Scribe\"},\"problem_section\":{\"title\":\"Por que as Consultas por Vídeo Importam\",\"features\":[{\"title\":\"Telessaúde Acessível em Qualquer Lugar\",\"description\":\"Os pacientes não precisam atrasar cuidados ou depender apenas de ferramentas digitais — consultas seguras de telemedicina facilitam a conexão de qualquer lugar.\"},{\"title\":\"Relações Mais Fortes com Pacientes\",\"description\":\"Mantenha-se conectado entre consultas com orientação confiável de telessaúde e comunicação contínua.\"},{\"title\":\"Prática Preparada para o Futuro\",\"description\":\"Ofereça serviços flexíveis de telemedicina ao lado de cuidados presenciais, mantendo sua prática moderna na era da AI.\"}]},\"seamless_access\":{\"badge\":\"Acesso Perfeito do Paciente\",\"title\":\"Acesso Perfeito do Paciente\",\"subtitle\":\"Os pacientes agendam e pagam por consultas por vídeo através do portal ou aplicativo, depois simplesmente fazem login e entram na chamada no horário da consulta.\",\"features\":[\"Os pacientes agendam e pagam por consultas por vídeo através do portal ou aplicativo.\",\"No horário da consulta, eles simplesmente fazem login e entram na chamada.\",\"Os prestadores de serviços veem as consultas por vídeo em sua agenda como qualquer outro serviço.\"],\"image_alt\":\"Paciente agendando e acessando consulta por vídeo através do portal\"},\"clinical_workflow\":{\"badge\":\"Fluxo de Trabalho Clínico Integrado\",\"title\":\"Fluxo de Trabalho Clínico Integrado\",\"subtitle\":\"Complete a documentação clínica com anotações, prescrições e faturamento perfeitamente integrados ao seu fluxo de trabalho existente.\",\"features\":[\"Os prestadores de serviços podem visualizar o registro de saúde do paciente durante a chamada.\",\"Faça anotações em tempo real, que fluem para o registro do encontro.\",\"Após a chamada, crie documentos de consulta, prescrições ou pedidos de laboratório.\",\"As anotações estão disponíveis para o AI Scribe se usado para gerar documentos de consulta.\"],\"image_alt\":\"Fluxo de trabalho clínico integrado durante consulta por vídeo\"},\"consultation_options\":{\"badge\":\"Opções Flexíveis de Consulta\",\"title\":\"Opções Flexíveis de Consulta\",\"subtitle\":\"Suporte diferentes tipos de consultas desde consultas agendadas até chamadas instantâneas e modos de vídeo assistidos para várias necessidades dos pacientes.\",\"options\":[{\"title\":\"Consultas Agendadas\",\"description\":\"Definidas por duração de serviço (por exemplo, 15 ou 30 minutos) com capacidade de estender.\"},{\"title\":\"Chamadas Instantâneas\",\"description\":\"Chamadas rápidas sem agendamento com participantes extras opcionais (cuidadores, tradutores, etc.).\"},{\"title\":\"Modo de Vídeo Assistido\",\"description\":\"Enfermeiros ou funcionários podem ajudar pacientes em locais remotos ou de baixa tecnologia a participar de chamadas com prestadores de serviços.\"}],\"image_alt\":\"