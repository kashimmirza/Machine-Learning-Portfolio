{\"title\":\"Consultas\",\"description\":\"Documentação completa de encontros com notas SOAP e resumos de consulta\",\"link\":\"/platform/consultation-notes\"},{\"title\":\"AI Scribe\",\"description\":\"Transcrição de áudio e documentos de consulta gerados por AI com modelos personalizados\",\"link\":\"/platform/ai-scribe\"},{\"title\":\"Prescrições\",\"description\":\"Prescrições eletrônicas com gestão de medicamentos e rastreamento de adesão do paciente\",\"link\":\"/platform/e-prescription-software\"},{\"title\":\"Pedidos de Laboratório\",\"description\":\"Gestão digital de pedidos de laboratório com rastreamento de resultados e notificação do paciente\",\"link\":\"/platform/lab-orders\"},{\"title\":\"Modelos de Documentos de AI\",\"description\":\"Modelos de documentos assistidos por AI personalizados para documentação de consulta simplificada\"}],\"image_alt\":\"Gestão de Consultas\"},\"practice\":{\"title\":\"Gestão de Consultório\",\"subtitle\":\"Gestão essencial de operações de consultório cobrindo consultas, faturamento, administração de pacientes e coordenação de equipe.\",\"features\":[{\"title\":\"Consultas\",\"description\":\"Autoagendamento com integração de pagamento e gestão automatizada de agendamento\",\"link\":\"/platform/appointment-scheduling-software\"},{\"title\":\"Faturamento\",\"description\":\"Faturamento automatizado com integração de gateway de pagamento, créditos e gestão de descontos\",\"link\":\"/platform/billing-payments\"},{\"title\":\"Administração de Pacientes\",\"description\":\"Integração conforme de pacientes, gestão de registro e rastreamento de consentimento\",\"link\":\"/platform/patient-administration\"},{\"title\":\"Gestão de Equipe\",\"description\":\"Perfis de profissionais, contas de membros da equipe, permissões baseadas em funções e coordenação de equipe\"}],\"image_alt\":\"Gestão de Consultório\"},\"patient_engagement\":{\"title\":\"Engajamento do Paciente\",\"subtitle\":\"Ferramentas abrangentes de comunicação e engajamento do paciente para construir relacionamentos mais fortes, melhorar resultados de saúde e aumentar a satisfação do paciente.\",\"features\":[{\"title\":\"Notificações\",\"description\":\"Mensagens automatizadas e personalizadas multicanal (email, SMS, push)\",\"link\":\"/platform/patient-notifications\"},{\"title\":\"Blog de Saúde\",\"description\":\"Publicação de conteúdo educacional para educação do paciente\",\"link\":\"/platform/health-blog-platform\"},{\"title\":\"Feedback do Paciente\",\"description\":\"Coleta estruturada de feedback e gestão de depoimentos\",\"link\":\"/platform/patient-feedback-management\"},{\"title\":\"Suporte ao Paciente\",\"description\":\"Integração do WhatsApp para suporte não médico\",\"link\":\"/platform/patient-support\"}],\"image_alt\":\"Ferramentas de Engajamento do Paciente\"},\"digital_front_door\":{\"title\":\"Porta de Entrada Digital\",\"subtitle\":\"Gestão completa de pontos de contato digitais com portais do paciente de marca, aplicativos móveis e interfaces white-label para experiência perfeita do paciente.\",\"features\":[{\"title\":\"Portal Web do Paciente\",\"description\":\"Portal abrangente do paciente baseado na web com agendamento de consultas e acesso ao prontuário de saúde\",\"link\":\"/platform/web-patient-portal\"},{\"title\":\"Aplicativo Móvel do Paciente\",\"description\":\"Aplicativo móvel nativo para pacientes com acesso completo ao consultório e gestão de saúde\",\"link\":\"/platform/patient-mobile-app\"},{\"title\":\"Aplicativo Móvel do Profissional\",\"description\":\"Aplicativo móvel para profissionais de saúde com gestão de pacientes e ferramentas de consulta\",\"link\":\"/platform/provider-mobile-apps\"},{\"title\":\"Site de Marketing\",\"description\":\"Site profissional do consultório com CMS integrado e otimização SEO\",\"link\":\"/platform/practice-marketing-website\"},{\"title\":\"White-labelling\",\"description\":\"Personalização completa de marca com domínios personalizados e sem marca ContinuousCare\",\"link\":\"/solutions/white-label-telemedicine-platform\"}],\"image_alt\":\"Porta de Entrada Digital\"}},\"use_cases\":{\"title\":\"Quem se Beneficia da Virtual Practice®?\",\"subtitle\":\"Nossa plataforma é projetada para atender às diversas necessidades de profissionais de saúde em diferentes tamanhos de consultório e especialidades.\",\"clinics\":{\"title\":\"Clínicas e Consultórios\",\"description\":\"Simplifique operações diárias e reduza a carga de documentação enquanto melhora a qualidade do atendimento ao paciente.\",\"benefits\":[\"Reduza significativamente o tempo de documentação\",\"Melhore o engajamento e a satisfação do paciente\",\"Aumente a receita através de operações eficientes\"],\"link\":\"/solutions/medical-practice-management-software\",\"link_text\":\"Saiba Mais\"},\"startups\":{\"title\":\"Startups de Saúde\",\"description\":\"Lance plataformas de marca rapidamente com capacidades de white-labelling e configuração rápida.\",\"benefits\":[\"Vá ao mercado em semanas, não meses\",\"Configuração de marca e domínio personalizados\",\"Escale a infraestrutura conforme você cresce\"],\"link\":\"/solutions/digital-healthcare-startup-software\",\"link_text\":\"Saiba Mais\"}},\"faqs\":{\"title\":\"Perguntas Frequentes\",\"subtitle\":\"Tudo que você precisa saber sobre a Virtual Practice® e como ela pode transformar sua prestação de cuidados de saúde.\",\"questions\":[{\"question\":\"O que é uma Virtual Practice®?\",\"answer\":\"Uma Virtual Practice® é uma plataforma completa de clínica digital combinando prontuários de saúde, consultas alimentadas por AI, telemedicina, monitoramento remoto de pacientes e ferramentas de engajamento do paciente sob um sistema de marca.\"},{\"question\":\"Como o AI Scribe é diferente de ferramentas isoladas?\",\"answer\":\"Ao contrário de scribes isolados, o AI Scribe na Virtual Practice® está incorporado no prontuário de saúde do paciente, garantindo que cada nota seja contextual, estruturada e vinculada ao histórico de cuidados.\"},{\"question\":\"Os pacientes podem usar um aplicativo móvel para agendar e acessar prontuários?\",\"answer\":\"Sim. Os pacientes podem usar o aplicativo móvel ContinuousCare — ou seu aplicativo white-label — para agendar consultas, fazer pagamentos e acessar seu prontuário de saúde completo.\"},{\"question\":\"Podemos fazer white-label completo da plataforma?\",\"answer\":\"Sim. Você pode mapear a Virtual Practice® para seu domínio, remover toda a marca ContinuousCare e publicar seus próprios aplicativos móveis de marca.\"},{\"question\":\"Ela suporta pagamentos e faturamento?\",\"answer\":\"Sim. O faturamento é automatizado para serviços configurados, e você pode conectar seu gateway de pagamento para que os pagamentos dos pacientes vão diretamente para sua conta.\"},{\"question\":\"A plataforma é segura e conforme?\",\"answer\":\"Sim. A Virtual Practice® inclui integração conforme de pacientes, permissões configuráveis para profissionais e administradores, e notificações seguras para PHI em todos os canais.\"}]},\"cta\":{\"title\":\"Transforme Sua Clínica com a Virtual Practice®\",\"subtitle\":\"Junte-se a milhares de profissionais de saúde que revolucionaram seu consultório com nossa plataforma de clínica digital all-in-one.\",\"button_text\":\"Iniciar Teste Gratuito de 14 Dias\",\"button_link\":\"/register\",\"features_title\":\"Tudo que você precisa para ter sucesso\",\"features_description\":\"Plataforma completa com documentação de AI, EHR abrangente, faturamento integrado, prescrições eletrônicas, pedidos de laboratório, ferramentas de engajamento do paciente e marca white-label - tudo em uma solução.\",\"benefits\":[\"Não é necessário cartão de crédito\",\"Cancele a qualquer momento\"]}},\"white_label_solutions\":{\"meta\":{\"title\":\"Plataforma de Telemedicina White Label - ContinuousCare | Soluções de Saúde\",\"description\":\"Plataforma de telemedicina white label com marca personalizada, aplicativos móveis e soluções completas de cuidados virtuais. Lance seu serviço de saúde de marca rapidamente.\",\"og_title\":\"Plataforma de Telemedicina White Label - ContinuousCare\",\"og_description\":\"Plataforma de telemedicina white label com marca personalizada, aplicativos móveis e soluções completas de cuidados virtuais\"},\"hero\":{\"title\":\"Plataforma de Telemedicina White-Label—\",\"title_highlight\":\"Sob Sua Marca\",\"subtitle\":\"Lance um aplicativo e portal de saúde totalmente de marca com consultas por vídeo, EHR e ferramentas de engajamento do paciente—sem sinal de ContinuousCare.\",\"benefits\":[\"Sua Marca, Não a Nossa\",\"Aplicativos iOS e Android Publicados nas Suas Contas\",\"Telemedicina e Engajamento do Paciente White-Label\",\"Conforme com HIPAA e GDPR\"]},\"transform_section\":{\"title\":\"Transforme a Prestação de Cuidados com uma Plataforma de Telemedicina White-Label\",\"subtitle\":\"Lance seu próprio aplicativo e portal de saúde de marca em dias—não meses. Com nossa solução white-label, tudo, desde consultas por vídeo até prontuários de pacientes, funciona sob seu nome, logotipo e domínio—sem rastro de ContinuousCare. Encante pacientes, reduza custos de desenvolvimento e construa confiança duradoura com uma experiência de saúde digital que parece 100% sua.\",\"brand_presence\":{\"title\":\"Amplie Sua Presença de Marca\",\"features\":[{\"title\":\"Propriedade Total da Marca\",\"description\":\"Aplicativos publicados sob suas contas Apple e Google, com seu logotipo, cores e telas de abertura.\"},{\"title\":\"Experiência Perfeita\",\"description\":\"Pacientes acessam cuidados através do seu aplicativo, portal e domínio web de marca.\"},{\"title\":\"Aumente Confiança e Fidelidade\",\"description\":\"Emails, notificações e SMS todos carregam sua identidade—não a nossa.\"}]},\"patient_care\":{\"title\":\"Preste Cuidados Premium ao Paciente\",\"features\":[{\"title\":\"Telemedicina White-Label\",\"description\":\"Consultas seguras por vídeo e texto entregues sob sua marca.\"},{\"t