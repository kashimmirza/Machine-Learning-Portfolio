ataforma\",\"links\":{\"features\":\"Características\",\"security\":\"Seguridad\",\"integrations\":\"Integraciones\",\"api\":\"API\"}},\"company\":{\"title\":\"Empresa\",\"links\":{\"about\":\"Acerca de\",\"careers\":\"Carreras\",\"blog\":\"Blog\",\"contact\":\"Contacto\"}},\"support\":{\"title\":\"Soporte\",\"links\":{\"help_center\":\"Centro de Ayuda\",\"training\":\"Capacitación\",\"status\":\"Estado\",\"community\":\"Comunidad\"}},\"legal\":{\"title\":\"Legal\",\"links\":{\"privacy\":\"Privacidad\",\"terms\":\"Términos\",\"hipaa\":\"HIPAA\",\"security\":\"Seguridad\",\"responsible_disclosure\":\"Divulgación Responsable\"}}}}},\"consultations\":{\"video_consultations\":{\"meta\":{\"title\":\"Software de Consulta por Video para Telesalud - ContinuousCare | Soluciones de Salud\",\"description\":\"Software profesional de consulta por video para telesalud con videollamadas en HD, salas de espera virtuales, compartir pantalla, sesiones con múltiples participantes e integración perfecta con EHR para consultorios médicos.\",\"og_title\":\"Software de Consulta por Video para Telesalud - ContinuousCare\",\"og_description\":\"Software profesional de consulta por video para telesalud con videollamadas en HD e integración con EHR\"},\"structured_data\":{\"faq_questions\":[{\"question\":\"¿Cómo funcionan las consultas por video de telesalud en Virtual Practice?\",\"answer\":\"Los pacientes reservan y pagan por las visitas por video a través de su portal o aplicación móvil. A la hora programada, inician sesión y se unen de forma segura. Los profesionales ven la cita en su calendario, acceden al historial médico del paciente durante la llamada, toman notas y crean documentos de consulta, recetas u órdenes de laboratorio después.\"},{\"question\":\"¿Los pacientes y profesionales reciben recordatorios sobre las consultas por video?\",\"answer\":\"Sí. Se envían recordatorios automatizados para citas de telemedicina programadas, pagos y seguimientos. Las notificaciones pueden entregarse por correo electrónico, SMS o notificaciones push para reducir las ausencias y mantener a todos preparados.\"},{\"question\":\"¿Los pacientes necesitan aplicaciones especiales para las visitas de telemedicina?\",\"answer\":\"No. Los pacientes simplemente inician sesión a través de su portal de pacientes personalizado o aplicación móvil. Las consultas por video de telesalud se ejecutan directamente dentro de Virtual Practice, no se requieren descargas de terceros.\"},{\"question\":\"¿Puedo facturar las visitas de telesalud de la misma manera que las consultas presenciales?\",\"answer\":\"Sí. Las citas de telemedicina se definen como los servicios presenciales. Usted puede establecer la duración, cargos del servicio e impuestos; los pacientes pagan en línea; y los registros de facturación se generan automáticamente.\"},{\"question\":\"¿Qué sucede con las notas de una consulta por video?\",\"answer\":\"Las notas tomadas durante la consulta por video se almacenan en el registro de encuentros. Los profesionales pueden usarlas para generar documentos de consulta, recetas u órdenes de laboratorio. Si se utiliza AI Scribe, estas notas se incluyen como contexto para crear documentación clínica.\"},{\"question\":\"¿Puede más de una persona unirse a una llamada de telemedicina?\",\"answer\":\"Sí. Los profesionales pueden invitar a cuidadores, traductores o participantes adicionales para videollamadas instantáneas. Un modo de video asistido también permite que enfermeras o personal ayuden a pacientes en áreas remotas a conectarse con su profesional.\"},{\"question\":\"¿Las consultas por video de telesalud son seguras y cumplen con las normativas?\",\"answer\":\"Sí. Todas las visitas de telemedicina están encriptadas y cumplen con HIPAA, GDPR y otras regulaciones de salud. La personalización de marca es opcional: usted puede mantener el aspecto estándar o personalizar el portal y las aplicaciones para reflejar su marca.\"},{\"question\":\"¿Qué equipo necesitan los pacientes para las visitas de telesalud?\",\"answer\":\"Un teléfono inteligente, tableta o computadora con cámara y una conexión a internet confiable es suficiente. No se requiere hardware adicional para la mayoría de las consultas por video.\"}],\"product\":{\"name\":\"Consultas por Video de Virtual Practice\",\"alternateName\":\"Plataforma de Telesalud y Telemedicina\",\"brand\":\"ContinuousCare\",\"description\":\"ContinuousCare Virtual Practice permite consultas por video seguras de telesalud y telemedicina para clínicas, consultorios pequeños y startups de salud digital. Los pacientes pueden reservar, pagar y unirse a visitas en línea a través de aplicaciones web o móviles, mientras los profesionales gestionan la programación, facturación y registros médicos en un sistema integrado.\",\"category\":\"Software de Telesalud\",\"audience\":\"Profesionales de la salud, Clínicas, Startups de Salud Digital\",\"keywords\":\"telesalud, telemedicina, consultas por video, plataforma de atención virtual, SaaS de salud, atención remota al paciente\"}},\"hero\":{\"title\":\"Software de Consulta por Video para Telesalud: \",\"title_highlight\":\"Atención Profesional\",\"title_suffix\":\" en Cualquier Lugar\",\"subtitle\":\"Brinde atención a través de visitas seguras de telemedicina, totalmente integradas con citas, facturación y registros médicos en su Virtual Practice.\",\"cta_text\":\"Iniciar Prueba Gratuita\",\"image_alt\":\"Profesional de la salud realizando consulta por video con AI Scribe\"},\"problem_section\":{\"title\":\"Por Qué Importan las Consultas por Video\",\"features\":[{\"title\":\"Telesalud Accesible en Cualquier Lugar\",\"description\":\"Los pacientes no tienen que retrasar la atención o depender solo de herramientas digitales: las visitas seguras de telemedicina facilitan la conexión desde cualquier lugar.\"},{\"title\":\"Relaciones Más Sólidas con los Pacientes\",\"description\":\"Manténgase conectado entre visitas con orientación confiable de telesalud y comunicación continua.\"},{\"title\":\"Consultorio Preparado para el Futuro\",\"description\":\"Ofrezca servicios flexibles de telemedicina junto con la atención presencial, manteniendo su consultorio moderno en la era de la AI.\"}]},\"seamless_access\":{\"badge\":\"Acceso Perfecto para Pacientes\",\"title\":\"Acceso Perfecto para Pacientes\",\"subtitle\":\"Los pacientes reservan y pagan por visitas por video a través del portal o aplicación, luego simplemente inician sesión y se unen a la llamada a la hora de la cita.\",\"features\":[\"Los pacientes reservan y pagan por visitas por video a través del portal o aplicación.\",\"A la hora de la cita, simplemente inician sesión y se unen a la llamada.\",\"Los profesionales ven las consultas por video en su agenda como cualquier otro servicio.\"],\"image_alt\":\"Paciente reservando y accediendo a consulta por video a través del portal\"},\"clinical_workflow\":{\"badge\":\"Flujo de Trabajo Clínico Integrado\",\"title\":\"Flujo de Trabajo Clínico Integrado\",\"subtitle\":\"Complete la documentación clínica con notas, recetas y facturación integradas perfectamente en su flujo de trabajo existente.\",\"features\":[\"Los profesionales pueden ver el historial médico del paciente durante la llamada.\",\"Tome notas en tiempo real, que fluyen hacia el registro de encuentros.\",\"Después de la llamada, cree documentos de consulta, recetas u órdenes de laboratorio.\",\"Las notas están disponibles para AI Scribe si se utiliza para generar documentos de consulta.\"],\"image_alt\":\"Flujo de trabajo clínico integrado durante consulta por video\"},\"consultation_options\":{\"badge\":\"Opciones de Consulta Flexibles\",\"title\":\"Opciones de Consulta Flexibles\",\"subtitle\":\"Admita diferentes tipos de consultas desde visitas programadas hasta llamadas instantáneas y modos de video asistido para diversas necesidades de los pacientes.\",\"options\":[{\"title\":\"Visitas Programadas\",\"description\":\"Definidas por la duración del servicio (por ejemplo, 15 o 30 minutos) con la capacidad de extender.\"},{\"title\":\"Llamadas Instantáneas\",\"description\":\"Llamadas rápidas sin cita con participantes adicionales opcionales (cuidadores, traductores, etc.).\"},{\"title\":\"Modo de Video Asistido\",\"description\":\"Enfermeras o personal pueden ayudar a pacientes en ubicaciones remotas o con baja tecnología a unirse a llamadas con profesionales.\"}],\"image_alt\":\"Opciones de consulta por video flexibles para diferentes necesidades de pacientes\"},\"collaboration\":{\"badge\":\"Colaboración Simplificada\",\"title\":\"Colaboración Simplificada\",\"subtitle\":\"Permita una comunicación y colaboración efectivas durante las consultas con compartir pantalla y soporte para múltiples participantes.\",\"features\":[\"Compartir pantalla durante las llamadas para explicar informes, resultados o planes de tratamiento.\",\"Las llamadas con múltiples participantes permiten una atención integral con cuidadores o personal de apoyo involucrados.\"],\"image_alt\":\"Compartir pantalla y colaboración con múltiples participantes durante consulta por video\"},\"security\":{\"badge\":\"Seguro, Conforme y Escalable\",\"title\":\"Seguridad y Cumplimiento de Nivel Empresarial\",\"features\":[\"Videollamadas encriptadas que cumplen con HIPAA/GDPR.\",\"Diseñado para consultorios médicos de todos los tamaños.\",\"Infraestructura escalable desde pequeñas clínicas hasta implementaciones empresariales.\"],\"image_alt\":\"Consultas por video seguras que cumplen con HIPAA con marca personalizada\"},\"digital_health_startups\":{\"badge\":\"Para Startups de Salud Digital\",\"title\":\"Para Startups de Salud Digital\",\"subtitle\":\"Lance su servicio rápidamente con un Virtual Practice listo para usar que puede personalizarse completamente con su marca.\",\"features\":[\"Aplicaciones web y móviles con marca personalizada bajo su nombre y dominio\",\"Desplegadas en sus propias cuentas de App Store\",\"Los pacientes solo ven su marca, no una pl