_app%2Fmulti-modal-care.png&amp;w=640&amp;q=75 1x, /_next/image?url=%2Fpatient_app%2Fmulti-modal-care.png&amp;w=1200&amp;q=75 2x" src="/_next/image?url=%2Fpatient_app%2Fmulti-modal-care.png&amp;w=1200&amp;q=75"/></div></div></div></div></section><section class="py-16 bg-gray-50"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center transition-all duration-700 opacity-0 translate-y-10"><div class="lg:w-full lg:order-1"><div class="relative"><img alt="Interfaz de aplicación móvil en smartphone" loading="lazy" width="600" height="450" decoding="async" data-nimg="1" class="rounded-2xl shadow-2xl w-full h-auto max-h-[600px] object-cover" style="color:transparent" srcSet="/_next/image?url=%2Fpatient_app%2Fnative-mobile-excellence.png&amp;w=640&amp;q=75 1x, /_next/image?url=%2Fpatient_app%2Fnative-mobile-excellence.png&amp;w=1200&amp;q=75 2x" src="/_next/image?url=%2Fpatient_app%2Fnative-mobile-excellence.png&amp;w=1200&amp;q=75"/></div></div><div class="lg:w-full space-y-8 lg:order-2"><div class="inline-block"><span class="bg-blue-light/20 text-blue-vibrant px-4 py-2 rounded-full text-sm font-medium border border-blue-vibrant/30">Excelencia Móvil</span></div><div><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-dark mb-6 leading-tight">Excelencia Móvil Nativa</h2><p class="text-xl text-slate-600 leading-relaxed max-w-xl">A diferencia de un sitio web responsivo, esta es una verdadera aplicación para iOS y Android, construida para dispositivos móviles desde cero.</p></div><div class="grid grid-cols-1 md:grid-cols-2 gap-8"><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-smartphone h-6 w-6 text-blue-vibrant flex-shrink-0 mt-1" aria-hidden="true"><rect width="14" height="20" x="5" y="2" rx="