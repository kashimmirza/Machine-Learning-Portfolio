w-6 text-blue-vibrant flex-shrink-0 mt-1" aria-hidden="true"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">Diseño Mobile-First</h3><p class="text-slate-600 text-sm">Optimizado para el tacto y la facilidad de uso del paciente.</p></div></div></div></div></div></div></div></section><section class="py-16 bg-white"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center transition-all duration-700 opacity-0 translate-y-10"><div class="lg:w-full space-y-8"><div class="inline-block"><span class="bg-purple-light/20 text-purple-accent px-4 py-2 rounded-full text-sm font-medium border border-purple-accent/30">Integración con el Consultorio</span></div><div><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-dark mb-6 leading-tight">Integración Perfecta con el Consultorio</h2><p class="text-xl text-slate-600 leading-relaxed max-w-xl">Todo lo que los pacientes hacen en la aplicación se conecta directamente con su Virtual Practice.</p></div><div class="grid grid-cols-1 md:grid-cols-2 gap-8"><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text h-6 w-6 text-purple-accent flex-shrink-0 mt-1" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path><path d="M14 2v4a2 2 0 0 0 2 2h4"></path><path d="M10 9H8"></path><path d="M16 13H8"></path><path d="M16 17H8"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">Documentación Compartida</h3><p class="text-slate-600 text-sm">Los pacientes acceden a recetas y resúmenes de consultas.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar h-6 w-6 text-purple-accent flex-shrink-0 mt-1" aria-hidden="true"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">Actualizaciones en Tiempo Real</h3><p class="text-slate-600 text-sm">Los cambios de citas se sincronizan automáticamente.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-square h-6 w-6 text-purple-accent flex-shrink-0 mt-1" aria-hidden="true"><path d="M22 17a2 2 0 0 1-2 2H6.828a2 2 0 0 0-1.414.586l-2.202 2.202A.71.71 0 0 1 2 21.286V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2z"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">Comunicación Segura</h3><p class="text-slate-600 text-sm">Los pacientes envían mensajes a los proveedores en un entorno conforme.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-zap h-6 w-6 text-purple-accent flex-shrink-0 mt-1" aria-hidden="true"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">Facturación Integrada</h3><p class="text-slate-600 text-sm">Los pacientes visualizan y pagan facturas desde su teléfono.</p></div></div></div></div></div><div class="lg:w-full"><div class="relative"><img alt="Proveedor de atención médica utilizando sistemas integrados" loading="lazy" width="600" height="450" decoding="async" data-nimg="1" class="rounded-2xl shadow-2xl w-full h-auto max-h-[600px] object-cover" style="color:transparent" srcSet="/_next/image?url=%2Fpatient_app%2Fseamless-provider-integration.png&amp;w=640&amp;q=75 1x, /_next/image?url=%2Fpatient_app%2Fseamless-provider-integration.png&amp;w=1200&amp;q=75 2x" src="/_next/image?url=%2Fpatient_app%2Fseamless-provider-integration.png&amp;w=1200&amp;q=75"/></div></div></div></div></section><section class="py-16 bg-gray-50"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center transition-all duration-700 opacity-0 translate-y-10"><div class="lg:w-full lg:order-1"><div class="relative"><img alt="Paciente utilizando funciones de gestión de salud" loading="lazy" width="600" height="450" decoding="async" data-nimg="1" class="rounded-2xl shadow-2xl w-full h-auto max-h-[600px] object-cover" style="color:transparent" srcSet="/_next/image?url=%2Fpatient_app%2F360-degree-patient-experience.png&amp;w=640&amp;q=75 1x, /_next/image?url=%2Fpatient_app%2F360-degree-patient-experience.png&amp;w=1200&amp;q=75 2x" src="/_next/image?url=%2Fpatient_app%2F360-degree-patient-experience.png&amp;w=1200&amp;q=75"/></div></div><div class="lg:w-full space-y-8 lg:order-2"><div class="inline-block"><span class="bg-green-muted/20 text-green-muted px-4 py-2 rounded-full text-sm font-medium border border-green-muted/30">Gestión de Salud</span></div><div><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-dark mb-6 leading-tight">Experiencia del Paciente de 360°</h2><p class="text-xl text-slate-600 leading-relaxed max-w-xl">Herramientas integrales al alcance de los pacientes.</p></div><div class="grid grid-cols-1 md:grid-cols-2 gap-8"><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar h-6 w-6 text-green-muted flex-shrink-0 mt-1" aria-hidden="true"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">Programación de Citas</h3><p class="text-slate-600 text-sm">Visitas por video o presenciales en unos pocos toques.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text h-6 w-6 text-green-muted flex-shrink-0 mt-1" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path><path d="M14 2v4a2 2 0 0 0 2 2h4"></path><path d="M10 9H8"></path><path d="M16 13H8"></path><path d="M16 17H8"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">Acceso a Registros Médicos</h3><p class="text-slate-600 text-sm">Resultados de laboratorio, recetas e historial de visitas bajo demanda.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users h-6 w-6 text-green-muted flex-shrink-0 mt-1" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><path d="M16 3.128a4 4 0 0 1 0 7.744"></path><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><circle cx="9" cy="7" r="4"></circle></svg><div><h3 class="font-semibold text-slate-800 mb-1">Gestión Familiar</h3><p class="text-slate-600 text-sm">Gestione dependientes dentro de una sola cuenta.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-camera h-6 w-6 text-green-muted flex-shrink-0 mt-1" aria-hidden="true"><path d="M13.997 4a2 2 0 0 1 1.76 1.05l.486.9A2 2 0 0 0 18.003 7H20a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h1.997a2 2 0 0 0 1.759-1.048l.489-.904A2 2 0 0 1 10.004 4z"></path><circle cx="12" cy="13" r="3"></circle></svg><div><h3 class="font-semibold text-slate-800 mb-1">Carga Segura de Archivos y Datos</h3><p class="text-slate-600 text-sm">Los pacientes pueden compartir fácilmente informes, documentos o datos de salud con sus proveedores a través de la aplicación.</p></div></div></div></div></div></div></div></section><section class="py-16 bg-gray-50"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center transition-all duration-700 opacity-0 translate-y-10"><div class="lg:w-full lg:order-1"><div class="relative"><img alt="Dispositivos de salud conectados y monitoreo" loading="lazy" width="600" height="450" decoding="async" data-nimg="1" class="rounded-2xl shadow-2xl w-full h-auto max-h-[600px] object-cover" style="color:transparent" srcSet="/_next/image?url=%2Fpatient_app%2Fconnected-health-devices.png&amp;w=640&amp;q=75 1x, /_next/image?url=%2Fpatient_app%2Fconnected-health-devices.png&amp;w=1200&amp;q=75 2x" src="/_next/image?url=%2Fpatient_app%2Fconnected-health-devices.png&amp;w=1200&amp;q=75"/></div></div><div class="lg:w-full space-y-8 lg:order-2"><div class="inline-block"><span class="bg-teal-primary/20 text-teal-primary px-4 py-2 rounded-full text-sm font-medium border border-teal-primary/30">Dispositivos Conectados</span></div><div><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-dark mb-6 leading-tight">Dispositivos de Salud Conectados</h2><p class="text-xl text-slate-600 leading-relaxed max-w-xl">Mantenga a los pacientes comprometidos entre visitas con integraciones de dispositivos.</p></div><div class="grid grid-cols-1 md:grid-cols-2 gap-8"><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-smartphone h-6 w-6 text-teal-primary flex-shrink-0 mt-1" aria-hidden="true"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"></rect><path d="M12 18h.01"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">Apple Health (iOS)</h3><p class="text-slate-600 text-sm">compatible.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-activity h-6 w-6 text-teal-primary flex-shrink-0 mt-1" aria-hidden="true"><path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">Google Health Connect (Android)</h3><p class="text-slate-600 text-sm">compatible.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-zap h-6 w-6 text-teal-primary flex-shrink-0 mt-1" aria-hidden="true"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">Compatibilidad con Dispositivos Bluetooth</h3><p class="text-slate-600 text-sm">Sincronice signos vitales directamente en el registro médico.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-heart h-6 w-6 text-teal-primary flex-shrink-0 mt-1" aria-hidden="true"><path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">Cargas Automatizadas</h3><p class="text-slate-600 text-sm">Los datos de salud fluyen hacia los registros de pacientes sin esfuerzo.</p></div></div></div></div></div></div></div></section><section class="py-16 bg-white"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="text-center mb-12"><h2 class="text-4xl md:text-5xl font-bold mb-6 text-slate-dark">Opciones para Cada Cliente</h2><div class="w-16 h-1 bg-blue-vibrant mx-auto mb-8"></div></div><div class="max-w-5xl mx-auto"><div class="grid grid-cols-1 md:grid-cols-2 gap-8"><div class="bg-blue-light/10 rounded-2xl p-8 border border-blue-light"><div class="text-center mb-6"><div class="inline-block"><span class="bg-blue-vibrant/20 text-blue-vibrant px-4 py-2 rounded-full text-sm font-medium border border-blue-vibrant/30">Opción Gratuita</span></div></div><h3 class="text-2xl font-bold text-slate-dark mb-4 text-center">Aplicación Gratuita de ContinuousCare</h3><p class="text-slate-600 leading-relaxed text-center mb-6">Rápida de implementar, disponible inmediatamente para todos sus pacientes.</p><div class="space-y-3"><div class="flex items-center gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-4 h-4 text-blue-vibrant flex-shrink-0" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg><span class="text-slate-600 text-sm">Disponibilidad inmediata</span></div><div class="flex items-center gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-4 h-4 text-blue-vibrant flex-shrink-0" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg><span class="text-slate-600 text-sm">No requiere configuración</span></div><div class="flex items-center gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-4 h-4 text-blue-vibrant flex-shrink-0" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg><span class="text-slate-600 text-sm">Funciones móviles básicas incluidas</span></div></div></div><div class="bg-gradient-to-br from-teal-primary/8 to-teal-primary/12 rounded-2xl p-8 border border-teal-primary/20 shadow-sm"><div class="text-center mb-6"><div class="inline-block"><span class="bg-teal-primary/20 text-teal-primary px-4 py-2 rounded-full text-sm font-medium border border-teal-primary/30">Complemento Opcional</span></div></div><h3 class="text-2xl font-bold text-slate-dark mb-4 text-center">Aplicación con Marca Personalizada</h3><p class="text-slate-600 leading-relaxed text-center mb-6">Publique bajo su propia marca con integraciones de dispositivos ampliadas y control total de la marca.</p><div class="space-y-3"><div class="flex items-center gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-4 h-4 text-teal-primary flex-shrink-0" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg><span class="text-slate-600 text-sm">Marca de su consultorio</span></div><div class="flex items-center gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-4 h-4 text-teal-primary flex-shrink-0" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg><span class="text-slate-600 text-sm">Más integraciones de dispositivos</span></div><div class="flex items-center gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check w-4 h-4 text-teal-primary flex-shrink-0" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg><span class="text-slate-600 text-sm">Publicada en sus propias cuentas de app store</span></div></div></div></div></div></div></section><section class="py-16 bg-gray-50"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="text-center mb-12"><h2 class="text-4xl md:text-5xl font-bold mb-6 text-slate-dark">Cómo Funciona</h2><div class="w-16 h-1 bg-blue-vibrant mx-auto mb-8"></div><p class="text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed">Proporcione a los pacientes un camino claro y simple para usar la aplicación móvil para pacientes</p></div><div class="max-w-6xl mx-auto"><div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 relative"><div class="text-center relative"><div class="relative mb-6"><div class="w-20 h-20 bg-blue-vibrant/10 rounded-3xl flex items-center justify-center mx-auto mb-4"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-smartphone h-10 w-10 text-blue-vibrant" aria-hidden="true"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"></rect><path d="M12 18h.01"></path></svg></div><div class="absolute -top-2 -right-2 w-8 h-8 bg-blue-vibrant text-white rounded-full flex items-center justify-center text-sm font-bold">1</div></div><h3 class="text-xl font-bold text-slate-dark mb-3">Descargue la Aplicación</h3><p class="text-slate-600 leading-relaxed">Los pacientes descargan la aplicación de ContinuousCare desde iOS App Store o Google Play. Si usted utiliza una versión con marca personalizada, ellos descargan su aplicación de marca en su lugar.</p><div class="hidden lg:block absolute top-10 -right-4 text-blue-vibrant/30"><svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg></div></div><div class="text-center relative"><div class="relative mb-6"><div class="w-20 h-20 bg-teal-primary/10 rounded-3xl flex items-center justify-center mx-auto mb-4"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield h-10 w-10 text-teal-primary" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path></svg></div><div class="absolute -top-2 -right-2 w-8 h-8 bg-teal-primary text-white rounded-full flex items-center justify-center text-sm font-bold">2</div></div><h3 class="text-xl font-bold text-slate-dark mb-3">Inicie Sesión de Forma Segura</h3><p class="text-slate-600 leading-relaxed">Los pacientes inician sesión con las mismas credenciales que utilizan para su portal web de Virtual Practice. Esto garantiza un acceso seguro y una experiencia unificada en web y móvil.</p><div class="hidden lg:block absolute top-10 -right-4 text-teal-primary/30"><svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg></div></div><div class="text-center relative"><div class="relative mb-6"><div class="w-20 h-20 bg-green-success/10 rounded-3xl flex items-center justify-center mx-auto mb-4"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-heart h-10 w-10 text-green-success" aria-hidden="true"><path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"></path></svg></div><div class="absolute -top-2 -right-2 w-8 h-8 bg-green-success text-white rounded-full flex items-center justify-center text-sm font-bold">3</div></div><h3 class="text-xl font-bold text-slate-dark mb-3">Acceda a la Atención en Cualquier Momento</h3><p class="text-slate-600 leading-relaxed">Una vez que hayan iniciado sesión, los pacientes pueden reservar citas, ver registros, pagar facturas y sincronizar datos de salud desde Apple Health, Google Health Connect o dispositivos compatibles.</p><div class="hidden lg:block absolute top-10 -right-4 text-green-success/30"><svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg></div></div><div class="text-center relative"><div class="relative mb-6"><div class="w-20 h-20 bg-purple-accent/10 rounded-3xl flex items-center justify-center mx-auto mb-4"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bell h-10 w-10 text-purple-accent" aria-hidden="true"><path d="M10.268 21a2 2 0 0 0 3.464 0"></path><path d="M3.262 15.326A1 1 0 0 0 4 17h16a1 1 0 0 0 .74-1.673C19.41 13.956 18 12.499 18 8A6 6 0 0 0 6 8c0 4.499-1.411 5.956-2.738 7.326"></path></svg></div><div class="absolute -top-2 -right-2 w-8 h-8 bg-purple-accent text-white rounded-full flex items-center justify-center text-sm font-bold">4</div></div><h3 class="text-xl font-bold text-slate-dark mb-3">Manténgase Conectado</h3><p class="text-slate-600 leading-relaxed">Los pacientes reciben notificaciones push para citas, resultados de laboratorio y actualizaciones del plan de atención, manteniéndolos comprometidos con su consultorio entre visitas.</p></div></div></div></div></section><section class="py-16 bg-white"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="text-center mb-12"><h2 class="text-3xl md:text-4xl font-bold mb-4">Customer Success Stories</h2><div class="w-24 h-1 bg-blue-vibrant mx-auto"></div></div><div class="grid grid-cols-1 lg:grid-cols-2 gap-8"><div class="bg-white rounded-lg p-8 shadow-lg"><div class="flex flex-col justify-between h-full"><p class="text-gray-700 italic mb-4">&quot;<!-- -->Virtual Practice platform is delivering next-generation medical care. As a multidisciplinary team, we find it powerful and intuitive for organizing patient cases, with clear medical records that support precise documentation and effective care.<!-- -->&quot;</p><div><p class="text-gray-700 font-medium">Dr. Georgios Leon - Metabolic Specialist</p><p class="text-gray-600">Precision Medicine Startup, Greece</p></div></div></div><div class="bg-white rounded-lg p-8 shadow-lg"><div class="flex flex-col justify-between h-full"><p class="text-gray-700 italic mb-4">&quot;<!-- -->I have been using the continuous care platform for several months and it has made a big impact in my practice, allowing me to monitor my patients more efficiently.<!-- -->&quot;</p><div><p class="text-gray-700 font-medium">Dr. Marie Christina Felix Douyon</p><p class="text-gray-600">Pulmonologist, Haiti</p></div></div></div></div></div></section><script type="application/ld+json">{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is the Patient Mobile App in the Virtual Practice?","acceptedAnswer":{"@type":"Answer","text":"The Patient Mobile App is the native iOS and Android application that comes with your Virtual Practice. It lets patients securely log in, book appointments, view health records, pay bills, and communicate with providers — all from their smartphones."}},{"@type":"Question","name":"Is the Patient Mobile App free for clinics to use?","acceptedAnswer":{"@type":"Answer","text":"Yes. Every Virtual Practice includes access to the free ContinuousCare patient app, which patients can download from the iOS App Store or Google Play. Clinics don't need to pay extra for their patients to use it."}},{"@type":"Question","name":"Can I have the app under my own brand name?","acceptedAnswer":{"@type":"Answer","text":"Yes. Startups and clinics that want their own branded app can choose the white-label option. This paid add-on publishes the app under your organization's App Store and Play Store accounts, with your name, logo, and branding."}},{"@type":"Question","name":"What can patients do with the app?","acceptedAnswer":{"@type":"Answer","text":"Patients can:\n\nBook video or in-person appointments\n\nView prescriptions, test results, and medical history\n\nReceive smart notifications and reminders\n\nPay bills online\n\nManage family member accounts\n\nSync health data automatically from supported devices"}},{"@type":"Question","name":"How does the app integrate with Apple Health and Google Health Connect?","acceptedAnswer":{"@type":"Answer","text":"Patients can grant permission to sync data from Apple Health (iOS) or Google Health Connect (Android) directly into their Virtual Practice health record. White-label apps also support additional Bluetooth health device integrations."}},{"@type":"Question","name":"Is the Patient Mobile App secure?","acceptedAnswer":{"@type":"Answer","text":"Yes. The app follows the same security and compliance standards as the Virtual Practice web portal. Data is encrypted in transit and at rest, and only patients and their authorized providers can view health information."}},{"@type":"Question","name":"Can providers send information to patients through the app?","acceptedAnswer":{"@type":"Answer","text":"Yes. Providers can share prescriptions, lab results, consultation notes, and care plan updates directly in the app. Patients receive instant notifications when new information is available."}},{"@type":"Question","name":"Do patients still have access to the web portal if they use the app?","acceptedAnswer":{"@type":"Answer","text":"Yes. The web portal and the mobile app are fully synchronized. Patients can use either or both, depending on their preference."}},{"@type":"Question","name":"Who supports patients if they face issues with the app?","acceptedAnswer":{"@type":"Answer","text":"The app is only a secure interface to each provider's Virtual Practice. Patients should contact their clinic or healthcare provider for help related to appointments, services, or care."}},{"@type":"Question","name":"Can clinics turn off the mobile app and only use the web portal?","acceptedAnswer":{"@type":"Answer","text":"Yes. Clinics that prefer not to use the mobile app can direct patients to use the web portal only. The choice is fully up to each Virtual Practice."}}]}</script><section class="py-16 bg-gray-50"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="text-center mb-12"><h2 class="text-3xl md:text-4xl font-bold mb-4">Frequently Asked Questions</h2><div class="w-24 h-1 bg-blue