iption\":\"Εφαρμογές δημοσιευμένες στους λογαριασμούς σας Apple και Google, με το λογότυπο, τα χρώματα και τις οθόνες εκκίνησής σας.\"},{\"title\":\"Απρόσκοπτη Εμπειρία\",\"description\":\"Οι ασθενείς έχουν πρόσβαση στη φροντίδα μέσω της εφαρμογής, της πύλης και του web domain σας με το brand σας.\"},{\"title\":\"Ενίσχυση Εμπιστοσύνης \u0026 Πίστης\",\"description\":\"Τα emails, οι ειδοποιήσεις και τα SMS φέρουν όλα την ταυτότητά σας—όχι τη δική μας.\"}]},\"patient_care\":{\"title\":\"Παρέχετε Premium Φροντίδα Ασθενών\",\"features\":[{\"title\":\"Τηλεϊατρική White-Labeled\",\"description\":\"Ασφαλείς διαβουλεύσεις βίντεο και κειμένου που παρέχονται κάτω από το brand σας.\"},{\"title\":\"Απομακρυσμένη Παρακολούθηση \u0026 Σχέδια Φροντίδας\",\"description\":\"Εμπλέξτε τους ασθενείς συνεχώς με 70+ trackers υγείας και εργαλεία χρόνιας φροντίδας.\"},{\"title\":\"Ενοποιημένα Αρχεία Ασθενών\",\"description\":\"ΗΑΥ, συνταγές και σημειώσεις διαβουλεύσεων—όλα διαθέσιμα σε μία εφαρμογή με brand.\"}]}},\"branded_app_section\":{\"badge\":\"Προσαρμοσμένο Branding\",\"title\":\"Η Εφαρμογή για Κινητά σας με Brand, Έτοιμη για Λανσάρισμα\",\"subtitle\":\"Παρέχετε φροντίδα μέσω μιας όμορφα σχεδιασμένης εφαρμογής για ασθενείς—πλήρως προσαρμοσμένη για το brand σας και δημοσιευμένη με το όνομά σας.\",\"features\":[{\"title\":\"Το Όνομα, το Λογότυπο \u0026 τα Χρώματά σας\",\"description\":\"Ενισχύστε την ταυτότητα του brand με προσαρμοσμένα θέματα, εικονίδια εφαρμογής και οθόνες εκκίνησης\"},{\"title\":\"Παρουσία στο App Store\",\"description\":\"Η εφαρμογή σας δημοσιεύεται με το brand σας στο Google Play και το App Store\"},{\"title\":\"Εμπειρία Mobile-First\",\"description\":\"Οι ασθενείς μπορούν να κλείσουν ραντεβού, να κάνουν διαβούλευση, να πληρώσουν και να στείλουν μήνυμα—όλα από την εφαρμογή για κινητά σας\"},{\"title\":\"Πλήρης Έλεγχος\",\"description\":\"Διαχειριστείτε το περιεχόμενο, τις υπηρεσίες και τις ενημερώσεις της εφαρμογής μέσω της πύλης διαχείρισής σας\"}]},\"engagement