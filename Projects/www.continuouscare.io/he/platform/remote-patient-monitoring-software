ription\":\"יומן הבריאות הוא חלק מהרשומה הרפואית האלקטרונית של המרפאה הוירטואלית. הוא מספק למטופלים מרחב מאובטח לכתוב הערות בריאות, הרהורים או תסמינים ולשתף ערכים נבחרים עם נותני שירותי הבריאות שלהם. נותני שירות יכולים גם להוסיף הערות לערכים משותפים, משפרים שיתוף פעולה והמשכיות הטיפול.\",\"features\":[\"רישום יומן דיגיטלי מאובטח\",\"שיתוף ערכים שנשלט על ידי המטופל\",\"הערות נותן שירות על הערות משותפות\",\"נגיש דרך פורטל מטופלים ואפליקציית נייד\",\"משולב עם רשומת הבריאות של המטופל\"]},\"hero\":{\"title\":\"רישום יומן\",\"title_highlight\":\"בריאות אישי\",\"title_suffix\":\"הפך פשוט\",\"subtitle\":\"תן למטופלים מרחב מאובטח לתעד את מסע הבריאות שלהם וכאשר הם בוחרים, שתף תובנות בעלות ערך עם צוות הטיפול שלהם.\",\"benefits\":[\"רישום יומן דיגיטלי מאובטח\",\"שיתוף הנשלט על ידי המטופל\",\"משולב עם הרשומה הרפואית\",\"נגיש באינטרנט ובנייד\"],\"image_alt\":\"מטופל מתעד את מסע הבריאות שלו ביומן דיגיטלי\"},\"problem_section\":{\"title\":\"למה יומן בריאות חשוב בטיפול יומיומי\",\"subtitle\":\"שיחות בריאות קצרות, אבל שינויי בריאות קורים כל יום. יומן הבריאות עוזר לגשר על פער זה.\",\"features\":[{\"title\":\"ללכוד חוויות יומיומיות\",\"description\":\"מטופלים יכולים לרשום תסמינים, התקדמות או הרהורים בין ביקורים.\"},{\"title\":\"תמיכה בזיכרון\",\"description\":\"יומנים עוזרים למטופלים לזכור מה קרה מאז הפגישה האחרונה שלהם.\"},{\"title\":\"מתן הקשר\",\"description\":\"נותני שירות רואים תמונה עשירה יותר כאשר מטופלים בוחרים לשתף.\"},{\"title\":\"עידוד מעורבות\",\"description\":\"מטופלים הופכים למשתתפים פעילים בטיפול שלהם.\"}]},\"patient_documentation\":{\"badge\":\"תיעוד ממוקד מטופל\",\"title\":\"מרחב פרטי להערות בריאות\",\"subtitle\":\"מטופלים יכולים לכתוב בחופשיות במילים שלהם - הערות קצרות או הרהורים ארוכים יותר - בידיעה שהם שולטים במה משותף.\",\"features\":[{\"title\":\"נגיש בכל עת באינטרנט או בנייד\",\"description\":\"זמין דרך התחברות קיימת לפורטל המטופלים\"},{\"title\":\"פורמט ערך גמיש, מהערות מהירות ועד סיפורים ארוכים יותר\",\"description\":\"כתוב במילים ובסגנון שלך\"},{\"title\":\"פר