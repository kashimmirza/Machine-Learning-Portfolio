"features\":[{\"title\":\"Signes Vitaux\",\"description\":\"Pression Artérielle, Niveau d'Oxygène, Pouls et Fréquence Respiratoire\"},{\"title\":\"Analyse Cardiaque\",\"description\":\"HRV, Stress Sympathique, Activité Parasympathique\"},{\"title\":\"Analyse Sanguine\",\"description\":\"Analyse de l'Hémoglobine et de l'Hémoglobine A1C\"},{\"title\":\"AI Avancé\",\"description\":\"Algorithmes AI avancés pour une extraction précise des mesures de santé\"}],\"image_alt\":\"Système de Santé Vidéo Alimenté par AI\"},\"custom_integration\":{\"title\":\"Options d'Intégration Personnalisée\",\"description\":\"ContinuousCare offre une personnalisation limitée pour les organisations qui ont besoin de support d'appareils au-delà des intégrations standard. Les options incluent des intégrations d'appareils personnalisées, l'extension du support de trackers et la personnalisation des appareils Linktop. Celles-ci sont évaluées au cas par cas et dépendent de la faisabilité technique et clinique.\",\"disclaimer\":\"Non pris en charge sur tous les forfaits. Contactez le Support pour discuter des options et des prochaines étapes.\"},\"cta_section\":{\"title\":\"Prêt à Connecter les Appareils de Vos Patients ?\",\"subtitle\":\"Intégrez les données des appareils Bluetooth, Apple Health, Google Health Connect et des systèmes basés sur AI directement dans le DSE — alimentant les soins continus et l'engagement patient.\",\"cta_text\":\"Démarrer l'Essai Gratuit\",\"description\":\"Découvrez comment les données des appareils affluent de manière fluide dans Virtual Practice pour soutenir les consultations et la Surveillance des Patients à Distance.\"},\"structured_data\":{\"name\":\"ContinuousCare — Intégrations d'Appareils Santé\",\"description\":\"Plateforme d'appareils santé connectés qui synchronise les appareils Bluetooth, Apple Health, Google Health Connect et les mesures alimentées par AI directement dans le DSE patient pour la surveillance continue des soins.\"}},\"remote_monitoring\":{\"meta\":{\"title\":\"Logiciel de Surveillance des Patients à Distance - ContinuousCare | Solutions de Santé\",\"description\":\"Logiciel complet de surveillance des patients à distance avec plus de 70 trackers de santé, seuils personnalisés, intégration DSE et plans de soins par abonnement pour les cabinets de santé.\"},\"hero\":{\"title\":\"Logiciel de Surveillance des Patients à Distance pour\",\"title_highlight\":\"Meilleurs Soins et Revenus Récurrents\",\"subtitle\":\"Gardez les patients connectés grâce à des plans de soins personnalisés, tout en créant des revenus récurrents durables pour votre cabinet.\",\"benefits\":[\"Suivez plus de 70 paramètres de santé avec des appareils connectés\",\"Définissez des seuils et alertes personnalisés pour les patients\",\"Intégration transparente Bluetooth et application mobile\",\"Proposez des applications mobiles personnalisées sous votre propre marque\"]},\"icon_features\":[\"Appareils Santé\",\"Plus de 70 Trackers Santé\",\"Plans de Soins\",\"Télésanté Asynchrone\"],\"how_it_works\":{\"title\":\"Comment Ça Marche\",\"subtitle\":\"Les patients suivent déjà leur santé et demandent même des informations à l'AI. Sans vos conseils, ces données manquent de contexte. RPM vous garde au centre — transformant les données brutes en soins de confiance, des relations plus fortes et de meilleurs résultats.\",\"steps\":[{\"title\":\"Choisissez Trackers et Appareils\",\"description\":\"Plus de 70 trackers intégrés avec appareils et applications.\"},{\"title\":\"Créez des Plans de Soins\",\"description\":\"Adaptés aux conditions ou à la récupération, avec seuils et rappels.\"},{\"title\":\"Visualisez les Données dans le DSE\",\"description\":\"Toutes les données surveillées affluent dans le dossier de chaque patient.\"},{\"title\":\"Répondez en Un Seul Endroit\",\"description\":\"Les prestataires agissent avec des retours et des prochaines étapes.\"}]},\"async_care\":{\"badge\":\"Soins Asynchrones\",\"title\":\"Efficacité de la Télésanté Asynchrone\",\"subtitle\":\"Avec la Surveillance des Patients à Distance, les prestataires n'ont pas besoin d'attendre les vérifications programmées pour agir. Les alertes précoces informent les équipes de soins des problèmes potentiels, permettant des soins préventifs qui conduisent à de meilleurs résultats et moins de visites d'urgence.\",\"features\":[\"Recevez des alertes lorsque l'attention est réellement requise\",\"Vous pouvez définir les fenêtres de révision et de réponse\",\"Plus de commodité et de satisfaction pour vos patients\",\"Plus de données permettent de meilleurs insights sur la santé\"]},\"care_scenarios\":{\"badge\":\"Gestion des Soins\",\"title\":\"Scénarios de Soins\",\"subtitle\":\"La Surveillance à Distance s'adapte à de multiples besoins de soins. Configurez des Équipes de Surveillance pour surveiller chaque cohorte de patients.\",\"scenarios\":[{\"title\":\"Gestion des Soins Chroniques :\",\"description\":\"Hypertension, diabète, insuffisance cardiaque, BPCO, et plus.\"},{\"title\":\"Surveillance Post-Chirurgicale :\",\"description\":\"Détectez les complications tôt, soutenez une récupération sûre.\"},{\"title\":\"Surveillance à Court Terme :\",\"description\":\"Infections ou conditions aiguës nécessitant un suivi étroit.\"}],\"conclusion\":\"Les plans de soins garantissent un soutien continu, aidant à construire des relations patient plus fortes et de meilleurs résultats de santé.\"},\"recurring_revenue\":{\"badge\":\"Croissance des Revenus\",\"title\":\"Revenus Récurrents avec Plans de Soins de Surveillance à Distance\",\"subtitle\":\"Avec les Plans de Soins RPM, vous pouvez générer de nouveaux revenus grâce aux services de soins préventifs. Cette approche proactive profite non seulement à la santé de vos patients mais améliore aussi l'efficacité et la rentabilité de votre cabinet.\",\"features\":[\"Définissez les frais d'abonnement et les cycles de renouvellement pour chaque plan de soins\",\"Acceptez les paiements d'abonnement et de renouvellement des patients\",\"Rappels de renouvellement aux patients\"]},\"practice_benefits\":{\"title\":\"Avantages pour Votre Cabinet\",\"benefits\":[{\"title\":\"Nouvelles Opportunités de Revenus\",\"description\":\"Offrez des plans de soins par abonnement pour les conditions chroniques et à court terme — créant un flux de revenus durable tout en soutenant de meilleurs résultats patients.\"},{\"title\":\"Engagement Patient Plus Fort\",\"description\":\"Gardez les patients connectés via leur portail et application mobile, avec rappels, alertes et points de contact continus qui améliorent l'adhésion.\"},{\"title\":\"Efficacité Opérationnelle\",\"description\":\"Intégration transparente avec les rendez-vous, la facturation, les notifications et les flux de travail de consultation — pas de connexions supplémentaires ou d'outils autonomes.\"},{\"title\":\"Prêt pour l'Avenir\",\"description\":\"Les données RPM enrichissent AI Scribe, aidant les prestataires à générer une documentation et des insights cliniques plus intelligents.\"}]},\"images\":{\"hero_alt\":\"Technologie et appareils de surveillance des patients à distance\",\"comprehensive_tracking_alt\":\"Appareils de suivi de santé complet et intégration smartphone\",\"async_care_alt\":\"Intelligence clinique alimentée par AI et évaluation de santé\",\"care_scenarios_alt\":\"Plateforme de communication multi-canaux avec SMS, email et WhatsApp\",\"recurring_revenue_alt\":\"Plateforme complète d'engagement patient avec applications mobiles personnalisées\"},\"problem_section\":{\"title\":\"Pourquoi Votre Cabinet A Besoin de RPM Avancé\",\"subtitle\":\"Les cabinets modernes ont du mal avec la gestion des maladies chroniques, l'engagement des patients entre les visites et la coordination des soins tout en faisant face à une complexité opérationnelle accrue.\",\"statistics\":[{\"value\":\"89%\",\"label\":\"des patients préfèrent l'engagement numérique en santé\"},{\"value\":\"76%\",\"label\":\"de réduction des réadmissions hospitalières réalisable\"},{\"value\":\"40%\",\"label\":\"d'amélioration de l'adhésion médicamenteuse des patients\"}]},\"comprehensive_tracking\":{\"badge\":\"Suivi de Santé Complet\",\"title\":\"Suivi de Santé Complet\",\"subtitle\":\"Surveillez plus de 70 paramètres de santé via appareils Bluetooth, Apple Health, Google Health Connect et mesures par caméra smartphone alimentées par AI.\",\"features\":[{\"title\":\"Plus de 70 Trackers Santé\",\"description\":\"Suivi pression artérielle, glucose, poids, fréquence cardiaque\"},{\"title\":\"Intégration d'Appareils Bluetooth\",\"description\":\"Glucomètres compatibles BLE, moniteurs cardiaques, brassards de tension\"},{\"title\":\"Connectivité Applications Santé\",\"description\":\"Intégration Apple Health et Google Health Connect\"},{\"title\":\"Mesures Smartphone AI\",\"description\":\"Signes vitaux par caméra incluant pression artérielle et oxygène\"}]},\"ai_intelligence\":{\"badge\":\"Intelligence Clinique Alimentée par AI\",\"title\":\"Intelligence Clinique Alimentée par AI\",\"subtitle\":\"Exploitez l'intelligence artificielle pour la documentation automatisée, les évaluations de santé vidéo et la génération intelligente de plans de soins pour une efficacité accrue.\",\"features\":[{\"title\":\"Intégration AI Scribe\",\"description\":\"Notes de consultation automatisées et documentation de plans de soins\"},{\"title\":\"Évaluation de Santé Vidéo\",\"description\":\"Analyse vidéo alimentée par AI pour insights cliniques\"},{\"title\":\"Système d'Alerte Intelligent\",\"description\":\"Notifications intelligentes pour mesures patients hors limites\"},{\"title\":\"Gestion de Plans de Soins\",\"description\":\"Plans de soins patients complets avec révision prestataire\"}]},\"communication_platform\":{\"badge\":\"Plateforme de Communication Multi-Canaux\",\"title\":\"Plateforme de Communication Multi-Canaux\",\"subtitle\":\"Gardez les patients engagés avec des notifications automatisées via SMS, email, WhatsA