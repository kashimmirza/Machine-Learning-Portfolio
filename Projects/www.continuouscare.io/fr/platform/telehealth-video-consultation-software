eatures\":\"Fonctionnalités\",\"security\":\"Sécurité\",\"integrations\":\"Intégrations\",\"api\":\"API\"}},\"company\":{\"title\":\"Entreprise\",\"links\":{\"about\":\"À Propos\",\"careers\":\"Carrières\",\"blog\":\"Blog\",\"contact\":\"Contact\"}},\"support\":{\"title\":\"Support\",\"links\":{\"help_center\":\"Centre d'Aide\",\"training\":\"Formation\",\"status\":\"Statut\",\"community\":\"Communauté\"}},\"legal\":{\"title\":\"Légal\",\"links\":{\"privacy\":\"Confidentialité\",\"terms\":\"Conditions\",\"hipaa\":\"HIPAA\",\"security\":\"Sécurité\",\"responsible_disclosure\":\"Divulgation Responsable\"}}}}},\"consultations\":{\"video_consultations\":{\"meta\":{\"title\":\"Logiciel de Consultation Vidéo par Télésanté - ContinuousCare | Solutions de Santé\",\"description\":\"Logiciel professionnel de consultation vidéo par télésanté avec appels vidéo HD, salles d'attente virtuelles, partage d'écran, sessions multi-participants et intégration transparente au dossier médical électronique pour les cabinets médicaux.\",\"og_title\":\"Logiciel de Consultation Vidéo par Télésanté - ContinuousCare\",\"og_description\":\"Logiciel professionnel de consultation vidéo par télésanté avec appels vidéo HD et intégration EHR\"},\"structured_data\":{\"faq_questions\":[{\"question\":\"Comment fonctionnent les consultations vidéo par télésanté dans le Virtual Practice ?\",\"answer\":\"Les patients réservent et paient les consultations vidéo via votre portail ou application mobile. À l'heure prévue, ils se connectent et rejoignent la session de manière sécurisée. Les prestataires voient le rendez-vous dans leur calendrier, accèdent au dossier médical du patient pendant l'appel, prennent des notes et créent des documents de consultation, des ordonnances ou des prescriptions d'analyses après l'appel.\"},{\"question\":\"Les patients et les prestataires reçoivent-ils des rappels concernant les consultations vidéo ?\",\"answer\":\"Oui. Des rappels automatiques sont envoyés pour les rendez-vous de télémédecine programmés, les paiements et les suivis. Les notifications peuvent être envoyées par e-mail, SMS ou notification push pour réduire les absences et maintenir tout le monde préparé.\"},{\"question\":\"Les patients ont-ils besoin d'applications spéciales pour les consultations de télémédecine ?\",\"answer\":\"Non. Les patients se connectent simplement via votre portail patient personnalisé ou votre application mobile. Les consultations vidéo par télésanté s'exécutent directement dans le Virtual Practice—aucun téléchargement tiers requis.\"},{\"question\":\"Puis-je facturer les consultations de télésanté de la même manière que les consultations en personne ?\",\"answer\":\"Oui. Les rendez-vous de télémédecine sont définis comme les services en personne. Vous pouvez définir la durée, les frais de service et les taxes ; les patients paient en ligne ; et les dossiers de facturation sont générés automatiquement.\"},{\"question\":\"Que deviennent les notes d'une consultation vidéo ?\",\"answer\":\"Les notes prises pendant la consultation vidéo sont stockées dans le journal de consultation. Les prestataires peuvent les utiliser pour générer des documents de consultation, des ordonnances ou des prescriptions d'analyses. Si AI Scribe est utilisé, ces notes sont incluses comme contexte pour créer la documentation clinique.\"},{\"question\":\"Plusieurs personnes peuvent-elles rejoindre un appel de télémédecine ?\",\"answer\":\"Oui. Les prestataires peuvent inviter des aidants, des traducteurs ou d'autres participants pour des appels vidéo instantanés. Un mode vidéo assisté permet également aux infirmières ou au personnel d'aider les patients dans des zones éloignées à se connecter à leur prestataire.\"},{\"question\":\"Les consultations vidéo par télésanté sont-elles sécurisées et conformes ?\",\"answer\":\"Oui. Toutes les consultations de télémédecine sont cryptées et conformes aux réglementations HIPAA, GDPR et autres réglementations de santé. La personnalisation en marque blanche est facultative—vous pouvez conserver l'apparence standard ou personnaliser le portail et les applications pour refléter votre marque.\"},{\"question\":\"Quel équipement les patients ont-ils besoin pour les consultations de télésanté ?\",\"answer\":\"Un smartphone, une tablette ou un ordinateur avec une caméra et une connexion Internet fiable suffit. Aucun matériel supplémentaire n'est requis pour la plupart des consultations vidéo.\"}],\"product\":{\"name\":\"Consultations Vidéo Virtual Practice\",\"alternateName\":\"Plateforme de Télésanté et Télémédecine\",\"brand\":\"ContinuousCare\",\"description\":\"ContinuousCare Virtual Practice permet des consultations vidéo sécurisées de télésanté et télémédecine pour les cliniques, petits cabinets et startups de santé numérique. Les patients peuvent réserver, payer et rejoindre des consultations en ligne via des applications web ou mobiles, tandis que les prestataires gèrent la planification, la facturation et les dossiers médicaux dans un système intégré.\",\"category\":\"Logiciel de Télésanté\",\"audience\":\"Prestataires de soins de santé, Cliniques, Startups de Santé Numérique\",\"keywords\":\"télésanté, télémédecine, consultations vidéo, plateforme de soins virtuels, SaaS santé, soins à distance\"}},\"hero\":{\"title\":\"Logiciel de Consultation Vidéo par Télésanté : \",\"title_highlight\":\"Soins Professionnels\",\"title_suffix\":\" Partout\",\"subtitle\":\"Offrez des soins via des consultations de télémédecine sécurisées, entièrement intégrées aux rendez-vous, à la facturation et aux dossiers médicaux dans votre Virtual Practice.\",\"cta_text\":\"Démarrer l'Essai Gratuit\",\"image_alt\":\"Prestataire de soins effectuant une consultation vidéo AI Scribe\"},\"problem_section\":{\"title\":\"Pourquoi les Consultations Vidéo Sont Importantes\",\"features\":[{\"title\":\"Télésanté Accessible Partout\",\"description\":\"Les patients n'ont pas à retarder les soins ou à se fier uniquement aux outils numériques — les consultations de télémédecine sécurisées facilitent la connexion de n'importe où.\"},{\"title\":\"Relations Patient Plus Fortes\",\"description\":\"Restez connecté entre les consultations avec des conseils de télésanté de confiance et une communication continue.\"},{\"title\":\"Cabinet Prêt pour l'Avenir\",\"description\":\"Offrez des services de télémédecine flexibles parallèlement aux soins en personne, maintenant votre cabinet moderne à l'ère de l'AI.\"}]},\"seamless_access\":{\"badge\":\"Accès Patient Transparent\",\"title\":\"Accès Patient Transparent\",\"subtitle\":\"Les patients réservent et paient les consultations vidéo via le portail ou l'application, puis se connectent simplement et rejoignent l'appel à l'heure du rendez-vous.\",\"features\":[\"Les patients réservent et paient les consultations vidéo via le portail ou l'application.\",\"À l'heure du rendez-vous, ils se connectent simplement et rejoignent l'appel.\",\"Les prestataires voient les consultations vidéo sur leur planning comme tout autre service.\"],\"image_alt\":\"Patient réservant et accédant à une consultation vidéo via le portail\"},\"clinical_workflow\":{\"badge\":\"Flux de Travail Clinique Intégré\",\"title\":\"Flux de Travail Clinique Intégré\",\"subtitle\":\"Documentation clinique complète avec notes, ordonnances et facturation intégrées de manière transparente dans votre flux de travail existant.\",\"features\":[\"Les prestataires peuvent consulter le dossier médical du patient pendant l'appel.\",\"Prenez des notes en temps réel, qui s'intègrent dans le journal de consultation.\",\"Après l'appel, créez des documents de consultation, des ordonnances ou des prescriptions d'analyses.\",\"Les notes sont disponibles pour AI Scribe si utilisé pour générer des documents de consultation.\"],\"image_alt\":\"Flux de travail clinique intégré pendant la consultation vidéo\"},\"consultation_options\":{\"badge\":\"Options de Consultation Flexibles\",\"title\":\"Options de Consultatio