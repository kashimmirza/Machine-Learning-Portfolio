4z"></path></svg></div></div><div><h3 class="font-semibold text-slate-800 mb-2">Повышает эффективность</h3><p class="text-slate-600 text-sm leading-relaxed">Сократите входящие звонки и ручное администрирование с помощью самообслуживания для записи на прием, записей и платежей.</p></div></div><div class="text-center space-y-3"><div class="flex justify-center"><div class="w-16 h-16 bg-teal-primary/10 rounded-2xl flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-heart h-8 w-8 text-teal-primary" aria-hidden="true"><path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"></path></svg></div></div><div><h3 class="font-semibold text-slate-800 mb-2">Укрепляет вовлеченность</h3><p class="text-slate-600 text-sm leading-relaxed">Push-уведомления и интеграция медицинских устройств способствуют лучшему соблюдению планов лечения.</p></div></div><div class="text-center space-y-3"><div class="flex justify-center"><div class="w-16 h-16 bg-teal-primary/10 rounded-2xl flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users h-8 w-8 text-teal-primary" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><path d="M16 3.128a4 4 0 0 1 0 7.744"></path><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><circle cx="9" cy="7" r="4"></circle></svg></div></div><div><h3 class="font-semibold text-slate-800 mb-2">Поддерживает ваш бренд</h3><p class="text-slate-600 text-sm leading-relaxed">Выберите между бесплатным приложением ContinuousCare или собственным приложением с белой меткой, опубликованным под названием вашей практики или стартапа.</p></div></div></div></div></div></div></section><section class="py-16 bg-white"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center transition-all duration-700 opacity-0 translate-y-10"><div class="lg:w-full space-y-8"><div class="inline-block"><span class="bg-green-success/20 text-green-success px-4 py-2 rounded-full text-sm font-medium border border-green-success/30">Мультимодальная помощь</span></div><div><h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-dark mb-6 leading-tight">Мультимодальная помощь</h2><p class="text-xl text-slate-600 leading-relaxed max-w-xl">Оказывайте помощь через каждый канал, который предпочитают ваши пациенты — все доступно в приложении.</p></div><div class="grid grid-cols-1 md:grid-cols-2 gap-8"><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar h-6 w-6 text-green-success flex-shrink-0 mt-1" aria-hidden="true"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">Очные консультации</h3><p class="text-slate-600 text-sm">Пациенты легко записываются и регистрируются.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-square h-6 w-6 text-green-success flex-shrink-0 mt-1" aria-hidden="true"><path d="M22 17a2 2 0 0 1-2 2H6.828a2 2 0 0 0-1.414.586l-2.202 2.202A.71.71 0 0 1 2 21.286V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2z"></path></svg><div><h3 class="font-semibold text-slate-800 mb-1">Текстовые консультации</h3><p class="text-slate-600 text-sm">Безопасный обмен сообщениями для несрочных вопросов.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-video h-6 w-6 text-green-success flex-shrink-0 mt-1" aria-hidden="true"><path d="m16 13 5.223 3.482a.5.5 0 0 0 .777-.416V7.87a.5.5 0 0 0-.752-.432L16 10.5"></path><rect x="2" y="6" width="14" height="12" rx="2"></rect></svg><div><h3 class="font-semibold text-slate-800 mb-1">Видеоконсультации</h3><p class="text-slate-600 text-sm">Высококачественные телемедицинские визиты прямо из приложения.</p></div></div></div><div class="space-y-4"><div class="flex items-start gap-3"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-monitor h-6 w-6 text-green-success flex-shrink-0 mt-1" aria-hidden="true"><rect width="20" height="14" x="2" y="3" rx="2"></rect><line x1="8" x2="16" y1="21" y2="21"></line><line x1="12" x2="12" y1="17" y2="21"></line></svg><div><h3 class="font-semibold text-slate-800 mb-1">Дистанционный мониторинг пациентов</h3><p class="text-slate-600 text-sm">Постоянное отслеживание здоровья с подключенными устройствами и планами лечения.</p></div></div></div></div></div><div class="lg:w-full"><div class="relative"><img alt="Мультимодальное предоставление медицинской помощи" loading="lazy" width="600" height="450" decoding="async" data-nimg="1" class="rounded-2xl shadow-2xl w-full h-auto max-h-[600px] object-cover" style="color:transparent" srcSet="/_next/image?url=%2Fpatient_app%2Fmulti-modal-care.png&amp;w=640&amp;q=75 1x, /_next/image?url=%2Fpatient_app%2Fmulti-modal-care.png&amp;w=1200&amp;q=75 2x" src="/