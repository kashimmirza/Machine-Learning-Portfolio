nch_solutions\":\"Решения для запуска\",\"custom_branding\":\"Индивидуальный брендинг\"}},\"platform\":{\"title\":\"Платформа\",\"links\":{\"features\":\"Функции\",\"security\":\"Безопасность\",\"integrations\":\"Интеграции\",\"api\":\"API\"}},\"company\":{\"title\":\"Компания\",\"links\":{\"about\":\"О нас\",\"careers\":\"Карьера\",\"blog\":\"Блог\",\"contact\":\"Контакты\"}},\"support\":{\"title\":\"Поддержка\",\"links\":{\"help_center\":\"Центр помощи\",\"training\":\"Обучение\",\"status\":\"Статус\",\"community\":\"Сообщество\"}},\"legal\":{\"title\":\"Юридическое\",\"links\":{\"privacy\":\"Конфиденциальность\",\"terms\":\"Условия\",\"hipaa\":\"HIPAA\",\"security\":\"Безопасность\",\"responsible_disclosure\":\"Ответственное раскрытие\"}}}}},\"consultations\":{\"video_consultations\":{\"meta\":{\"title\":\"Программное обеспечение для видеоконсультаций телемедицины - ContinuousCare | Решения для здравоохранения\",\"description\":\"Профессиональное программное обеспечение для видеоконсультаций телемедицины с видеозвонками HD, виртуальными залами ожидания, совместным использованием экрана, многопользовательскими сессиями и бесшовной интеграцией с ЭМК для медицинских практик.\",\"og_title\":\"Программное обеспечение для видеоконсультаций телемедицины - ContinuousCare\",\"og_description\":\"Профессиональное программное обеспечение для видеоконсультаций телемедицины с видеозвонками HD и интеграцией с ЭМК\"},\"structured_data\":{\"faq_questions\":[{\"question\":\"Как работают видеоконсультации телемедицины в Виртуальной практике?\",\"answer\":\"Пациенты бронируют и оплачивают видеовизиты через ваш портал или мобильное приложение. В назначенное время они входят в систему и присоединяются безопасно. Провайдеры видят встречу в своем календаре, имеют доступ к медицинской записи пациента во время звонка, делают заметки и создают консультационные документы, рецепты или заказы на анализы после этого.\"},{\"question\":\"Получают ли пациенты и провайдеры напоминания о видеоконсультациях?\",\"answer\":\"Да. Автоматические напоминания отправляются для запланированных телемедицинских встреч, платежей и последующих визитов. Уведомления могут быть доставлены по электронной почте, SMS или push-уведомлением, чтобы уменьшить неявки и держать всех в курсе.\"},{\"question\":\"Нужны ли пациентам специальные приложения для телемедицинских визитов?\",\"answer\":\"Нет. Пациенты просто входят через ваш брендированный портал пациентов или мобильное приложение. Видеоконсультации телемедицины запускаются прямо внутри Виртуальной практики — никаких сторонних загрузок не требуется.\"},{\"question\":\"Могу ли я выставлять счета за телемедицинские визиты так же, как за личные консультации?\",\"answer\":\"Да. Телемедицинские встречи определяются так же, как личные услуги. Вы можете установить продолжительность, плату за услуги и налоги; пациенты платят онлайн; и счета генерируются автоматически.\"},{\"question\":\"Что происходит с заметками из видеоконсультации?\",\"answer\":\"Заметки, сделанные во время видеоконсультации, хранятся в журнале приема. Провайдеры могут использовать их для создания консультационных документов, рецептов или заказов на анализы. Если используется AI Scribe, эти заметки включаются в качестве контекста для создания клинической документации.\"},{\"question\":\"Может ли более одного человека присоединиться к телемедицинскому звонку?\",\"answer\":\"Да. Провайдеры могут приглашать опекунов, переводчиков или дополнительных участников для мгновенных видеозвонков. Режим вспомогательного видео также позволяет медсестрам или персоналу помогать пациентам в удаленных областях подключаться к своему провайдеру.\"},{\"question\":\"Являются ли видеоконсультации телемедицины безопасными и соответствующими требованиям?\",\"answer\":\"Да. Все телемедицинские визиты зашифрованы и соответствуют HIPAA, GDPR и другим медицинским нормативам. Белая маркировка необязательна — вы можете сохранить стандартный вид или настроить портал и приложения, чтобы отразить ваш бренд.\"},{\"question\":\"Какое оборудование нужно пациентам для телемедицинских визитов?\",\"answer\":\"Достаточно смартфона, планшета или компьютера с камерой и надежным интернет-соединением. Для большинства видеоконсультаций не требуется дополнительное оборудование.\"}],\"product\":{\"name\":\"Видеоконсультации виртуальной практики\",\"alternateName\":\"Платформа телемедицины и телездравоохранения\",\"brand\":\"ContinuousCare\",\"description\":\"ContinuousCare Virtual Practice обеспечивает безопасные видеоконсультации телемедицины и телездравоохранения для клиник, малых практик и стартапов в области цифрового здравоохранения. Пациенты могут бронировать, оплачивать и присоединяться к онлайн-визитам через веб или мобильные приложения, в то время как провайдеры управляют планированием, выставлением счетов и медицинскими записями в одной интегрированной системе.\",\"category\":\"Программное обеспечение для телездравоохранения\",\"audience\":\"Поставщики медицинских услуг, клиники, стартапы в области цифрового здравоохранения\",\"keywords\":\"телездравоохранение, телемедицина, видеоконсультации, платформа виртуальной помощи, SaaS для здравоохранения, удаленный уход за пациентами\"}},\"hero\":{\"title\":\"Программное обеспечение для видеоконсультаций телемедицины: \",\"title_highlight\":\"Профессиональная помощь\",\"title_suffix\":\" везде\",\"subtitle\":\"Оказывайте помощь через безопасные телемедицинские визиты, полностью интегрированные с встречами, выставлением счетов и медицинскими записями в вашей Виртуальной практике.\",\"cta_text\":\"Начать бесплатную пробную версию\",\"image_alt\":\"Поставщик медицинских услуг проводит видеоконсультацию с AI Scribe\"},\"problem_section\":{\"title\":\"Почему важны видеоконсультации\",\"features\":[{\"title\":\"Доступное телездравоохранение везде\",\"description\":\"Пациентам не нужно откладывать лечение или полагаться только на цифровые инструменты — безопасные телемедицинские визиты облегчают связь из любого места.\"},{\"title\":\"Более крепкие отношения с пациентами\",\"description\":\"Оставайтесь на связи между визитами с надежным руководством по телездравоохранению и постоянной коммуникацией.\"},{\"title\":\"Практика будущего\",\"description\":\"Предлагайте гибкие телемедицинские услуги наряду с личной помощью, сохраняя вашу практику современной в эпоху ИИ.\"}]},\"seamless_access\":{\"badge\":\"Бесшовный доступ пациентов\",\"title\":\"Бесшовный доступ пациентов\",\"subtitle\":\"Пациенты бронируют и оплачивают видеовизиты через портал или приложение, затем просто входят и присоединяются к звонку в назначенное время.\",\"features\":[\"Пациенты бронируют и оплачивают видеовизиты через портал или приложение.\",\"В назначенное время они просто входят и присоединяются к звонку.\",\"Провайдеры видят видеоконсультации в своем расписании, как любую другую услугу.\"],\"image_alt\":\"Пациент бронирует и получает доступ к видеоконсультации через портал\"},\"clinical_workflow\":{\"badge\":\"Интегрированный клинический рабочий процесс\",\"title\":\"Интегрированный клинический рабочий процесс\",\"subtitle\":\"Завершите клиническую документацию с заметками, рецептами и выставлением счетов, бесшовно интегрированными в ваш существующий рабочий процесс.\",\"features\":[\"Провайдеры могут просматривать медицинскую запись пациента во время звонка.\",\"Делайте заметки в режиме реального времени, которые попадают в журнал приема.\",\"После звонка создавайте консультационные документы, рецепты или заказы на анализы.\",\"Заметки доступны для AI Scribe, если используются для создания консультационных документов.\"],\"image_alt\":\"Интегрированный клинический рабочий процесс во время видеоконсультации\"},\"consultation_options\":{\"badge\":\"Гибкие варианты консультаций\",\"title\":\"Гибкие варианты консультаций\",\"subtitle\":\"Поддерживайте различные типы консультаций: от запланированных визитов до мгновенных звонков и режимов вспомогательного видео для различных потребностей пациентов.\",\"options\":[{\"t