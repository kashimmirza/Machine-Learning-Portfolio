iption\":\"Отслеживайте обновления выполнения рецептов в реальном времени\"},{\"title\":\"Безопасный хостинг поддоменов\",\"description\":\"Все порталы аптек размещаются на вашем пользовательском домене практики\"}],\"image_alt\":\"Интеграция партнерской аптеки с отслеживанием в реальном времени и безопасными соединениями\"},\"cta_section\":{\"title\":\"Готовы оцифровать свой рабочий процесс рецептов?\",\"subtitle\":\"Начните генерировать и управлять рецептами с легкостью — прямо из вашей виртуальной практики. Включите безопасные цифровые рецепты с интегрированным выполнением аптекой и мгновенным доступом пациентов.\",\"button_text\":\"Начать бесплатный пробный период сегодня\",\"description_title\":\"Все необходимое для более умного управления рецептами\",\"description_text\":\"Создавайте, делитесь и выполняйте рецепты с легкостью — с указаниями дозировки, интеграциями аптек и мобильным доступом.\"}},\"lab_orders\":{\"meta\":{\"title\":\"Управление цифровыми заказами лабораторных исследований и результатами | Программное обеспечение виртуальной практики\",\"description\":\"Управляйте заказами лабораторных исследований беспрепятственно с помощью виртуальной практики. Провайдеры создают заказы после консультаций, пациенты получают к ним доступ и загружают их в любое время, администраторы лабораторий координируют с партнерами, а результаты безопасно поступают в медицинскую карту пациента.\"},\"hero\":{\"title\":\"Беспрепятственное управление заказами и результатами лабораторных исследований\",\"subtitle\":\"Обеспечьте плавную координацию между провайдерами, пациентами и партнерами лабораторий с помощью цифровых заказов лабораторных исследований, легкого доступа пациентов и безопасного обмена результатами.\",\"benefits\":[\"Цифровые заказы лабораторных исследований — создавайте, управляйте и делитесь заказами мгновенно после консультаций\",\"Прозрачность пациента — пациенты могут просматривать, загружать и печатать заказы лабораторных исследований в любое время\",\"Интегрированные результаты — загрузки партнера лаборатории автоматически обновляют медицинские записи пациентов\"],\"image_alt\":\"Точная система заказов лабораторных исследований для более умной диагностики\"},\"workflow_section\":{\"title\":\"Как виртуальная практика упрощает поток заказов лабораторных исследований\",\"subtitle\":\"От консультации до результатов все остается связанным. Убедитесь, что провайдеры, пациенты и партнеры лабораторий работают в синхронизации с цифровыми заказами лабораторных исследований, которые упрощают каждый шаг процесса.\",\"steps\":[{\"title\":\"Непосредственно из консультаций\",\"description\":\"Провайдеры мгновенно создают заказы лабораторных исследований после встреч с пациентами\"},{\"title\":\"Всегда доступно\",\"description\":\"Пациенты могут просматривать, загружать и печатать заказы через свой портал или приложение\"},{\"title\":\"Надзор администратора\",\"description\":\"Администраторы лабораторий отслеживают, назначают и координируют заказы с настроенными партнерами лабораторий\"},{\"title\":\"Автоматическое обновление записей\",\"description\":\"Результаты лабораторных исследований безопасно добавляются в медицинскую карту пациента\"},{\"title\":\"Интегрированное сотрудничество с партнерами\",\"description\":\"Гибкая настройка для одного или нескольких партнеров лабораторий\"}]},\"ordering_section\":{\"badge\":\"Упрощенное заказывание\",\"title\":\"Упростите заказ тестов во время консультаций\",\"subtitle\":\"Заказывайте лабораторные и визуализационные тесты всего несколькими кликами. Экономьте время во время визитов пациентов. Укажите типы тестов, приоритеты и инструкции для обеспечения точной диагностики.\",\"features\":[{\"title\":\"Упрощенное заказывание\",\"description\":\"Организуйте свои тесты несколькими кликами при заказе во время визитов пациентов\"},{\"title\":\"Приоритизированная точность\",\"description\":\"Устанавливайте приоритеты тестов от рутинных до срочных с четкими инструкциями\"},{\"title\":\"Прозрачнос