nsights\":\"Аналитика здоровья и трекеры с визуальными трендами и мониторингом\"},\"hero\":{\"title\":\"Умные электронные медицинские записи для связанного ухода\",\"subtitle\":\"Основа вашей виртуальной практики — доступная, ориентированная на пациента и интегрированная во все предоставляемые вами услуги.\",\"benefits\":[\"Полные истории пациентов в одном месте\",\"Синхронизация с более чем 70 трекерами здоровья и подключенными устройствами\",\"Безопасная загрузка и обмен медицинскими записями\",\"Конфиденциальность на основе ролей и соответствие по умолчанию\"]},\"problem_section\":{\"title\":\"Почему ЭМК виртуальной практики выделяется\",\"subtitle\":\"Больше чем просто цифровые карты, наша ЭМК — это центральный узел, который обеспечивает уход за пациентами, эффективность практики и постоянное взаимодействие.\",\"features\":[{\"title\":\"Репозиторий, ориентированный на пациента\",\"description\":\"Безопасные записи, доступные как пациенту, так и провайдеру для прозрачного совместного ухода.\"},{\"title\":\"Интегрирован во все услуги\",\"description\":\"Беспрепятственная работа во всех визитах, мониторинге и взаимодействиях с пациентами для полного контекста.\"},{\"title\":\"Данные за пределами клиники\",\"description\":\"Подключается к носимым устройствам, приложениям и устройствам для непрерывной информации о пациенте.\"},{\"title\":\"Поддержка лучших решений\",\"description\":\"Профили, отчеты и тренды здоровья позволяют принимать обоснованные персонализированные решения о лечении.\"},{\"title\":\"Соответствие и доверие встроены\",\"description\":\"Разрешения, журналы аудита и шифрование защищают конфиденциальность без замедления ухода.\"}]},\"comprehensive_profiles_section\":{\"badge\":\"Комплексный вид пациента\",\"title\":\"Всеобъемлющие профили здоровья\",\"subtitle\":\"От заболеваний и лекарств до аллергий, прививок, операций и семейной/социальной истории — каждая деталь находится в одной унифицированной записи.\",\"features\":[{\"title\":\"Прошлые и текущие заболевания в одном профиле\",\"description\":\"Комплексный вид медицинской истории пациента\"},{\"title\":\"Журналы лекарств, аллергий и противопоказаний\",\"description\":\"Полное отслеживание лекарств и информация о безопасности\"},{\"title\":\"Поддержка истории прививок и операций\",\"description\":\"Документированные записи об иммунизации и хирургических процедурах\"},{\"title\":\"Всегда обновляется и доступно\",\"description\":\"Обновления в реальном времени с мгновенным доступом\"}]},\"medical_records_section\":{\"badge\":\"Организовано и доступно для поиска\",\"title\":\"Медицинские записи и отчеты\",\"subtitle\":\"Все медицинские документы — результаты анализов, сканирование, выписные эпикризы и DICOM-изображения — безопасно хранятся и легко извлекаются.\",\"features\":[{\"title\":\"Загрузка в нескольких форматах и поддержка DICOM\",\"description\":\"Поддержка всех форматов медицинских документов\"},{\"title\":\"Доступ на основе ролей для провайдеров и персонала\",\"description\":\"Контролируемый доступ с соответствующими разрешениями\"},{\"title\":\"Пациенты могут добавлять свои собственные отчеты\",\"description\":\"Документация, предоставленная пациентом\"},{\"title\":\"Безопасная загрузка при необходимости\",\"description\":\"Безопасное извлечение и обмен документами\"}]},\"health_trackers_section\":{\"badge\":\"Мониторинг в реальном времени\",\"title\":\"Трекеры и аналитика здоровья\",\"subtitle\":\"Отслеживайте жизненно важные показатели, симптомы и результаты тестов с помощью более 70 поддерживаемых трекеров, многие из которых интегрированы с Apple Health, Google Health Connect и медицинскими устройствами.\",\"features\":[{\"title\":\"Мониторинг жизненных показателей и метрик хронических заболеваний\",\"description\":\"Комплексное отслеживание жизненно важных показателей\"},{\"title\":\"Визуальные тренды с графиками и пороговыми значениями\",\"description\":\"Легко читаемые графики и анализ трендов\"},{\"title\":\"Интеграция устройств и приложений