"$undefined\"}]\n18:[\"$\",\"$L1c\",null,{\"translations\":\"$3:1:0:props:translations\"}]\n19:[\"$\",\"$L1d\",null,{\"children\":[[\"$\",\"$L1e\",null,{}],[\"$\",\"$L1f\",null,{\"excludeFromRoutes\":[\"/ai-marketing-assistant\"]}]]}]\n1a:[\"$\",\"link\",\"30\",{\"rel\":\"apple-touch-icon\",\"href\":\"/apple-touch-icon.png\",\"sizes\":\"180x180\",\"type\":\"image/png\"}]\n1b:[\"$\",\"$L20\",\"31\",{}]\n"])</script><script>self.__next_f.push([1,"21:T25bf,"])</script><script>self.__next_f.push([1,"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Что такое программное обеспечение для администрирования пациентов для клиник?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Программное обеспечение для администрирования пациентов помогает клиникам управлять регистрацией пациентов, приемами, выставлением счетов, записями и коммуникацией в одной безопасной системе. Оно снижает административную нагрузку, улучшает доступ пациентов и поддерживает данные организованными и соответствующими требованиям.\"}},{\"@type\":\"Question\",\"name\":\"Зачем моей клинике нужен портал и приложение для пациентов?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Портал и приложение для пациентов обеспечивают безопасный способ для пациентов бронировать приемы, совершать платежи, получать доступ к своим записям и общаться с поставщиками медицинских услуг. В отличие от электронной почты или SMS, портал обеспечивает шифрование конфиденциальной информации, основанную на согласии и соответствующую стандартам здравоохранения.\"}},{\"@type\":\"Question\",\"name\":\"Как эта система улучшает регистрацию и адаптацию пациентов?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Пациенты могут регистрироваться онлайн, предоставлять необходимые данные и давать юридическое согласие в цифровом формате. Это упрощает адаптацию, сокращает бумажную работу и обеспечивает безопасное хранение и доступность данных пациентов для персонала.\"}},{\"@type\":\"Question\",\"name\":\"Могут ли пациенты бронировать приемы и платить онлайн?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Да. Пациенты могут самостоятельно бронировать личные или телемедицинские визиты и безопасно платить онлайн или в клинике. Отмененные бронирования возвращаются в виде кредитов кошелька, защищая вашу клинику от проблем с возвратом платежей через платежный шлюз.\"}},{\"@type\":\"Question\",\"name\":\"Как управляются медицинские записи пациентов?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Медицинские записи, резюме визитов, рецепты и лабораторные заказы надежно хранятся и доступны через портал для пациентов. Пациенты видят только то, что должны, в то время как поставщики имеют полный клинический доступ через систему.\"}},{\"@type\":\"Question\",\"name\":\"Как система обрабатывает выставление счетов и платежи?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Выставление счетов связано с приемами и услугами. Пациенты получают четкие, детализированные счета, могут платить онлайн и получать автоматическое подтверждение оплаченных приемов. Клиники получают возвраты на основе кошелька, отслеживание доходов и несколько вариантов оплаты.\"}},{\"@type\":\"Question\",\"name\":\"Как система поддерживает безопасную коммуникацию с пациентами?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Платформа включает многоканальные уведомления для напоминаний, подтверждений и обновлений. Конфиденциальные документы и медицинские сообщения передаются только через портал, а не по электронной почте или SMS, обеспечивая безопасность и соответствие требованиям.\"}},{\"@type\":\"Question\",\"name\":\"Поддерживает ли программное обеспечение обратную связь с пациентами?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Да. Клиники могут собирать отзывы пациентов непосредственно через портал, что облегчает реагирование и улучшение услуг, сохраняя при этом безопасную запись взаимодействий.\"}},{\"@type\":\"Question\",\"name\":\"Насколько безопасна система администрирования пациентов?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Система использует шифрование, двухфакторную аутентификацию и встроенный сбор согласия для защиты данных пациентов. Она соответствует HIPAA и GDPR, обеспечивая соответствие всех взаимодействий стандартам конфиденциальности и безопасности здравоохранения.\"}},{\"@type\":\"Question\",\"name\":\"Может ли система быть брендирована для моей клиники?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Да. Каждая клиника запускает свою собственную брендированную виртуальную практику с порталом для пациентов, мобильным приложением и веб-сайтом на основе CMS, привязанным к вашему домену для согласованного опыта пациентов.\"}},{\"@type\":\"Question\",\"name\":\"Работает ли портал для пациентов на мобильных устройствах?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Да. Пациенты могут получить доступ к порталу через браузер или специализированные приложения для iOS и Android для согласованного, удобного для мобильных устройств опыта.\"}},{\"@type\":\"Question\",\"name\":\"Как эта система снижает количество неявок?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Автоматические напоминания отправляются по электронной почте, SMS или в виде уведомлений в приложении, а поставщики получают ежедневные дайджесты предстоящих приемов. Эти функции вместе помогают значительно сократить неявки.\"}},{\"@type\":\"Question\",\"name\":\"Может ли эта система обрабатывать несколько местоположений клиник?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Да. Приемы, записи и выставление счетов могут быть привязаны к конкретным поставщикам и местоположениям, что упрощает управление многофилиальными практиками в одной системе.\"}},{\"@type\":\"Question\",\"name\":\"Насколько легко начать работу?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Большинство клиник могут быстро настроиться, определив услуги, расписание поставщиков и настройки платежей. Система готова к использованию «из коробки», с доступной поддержкой для обучения и адаптации.\"}},{\"@type\":\"Question\",\"name\":\"Как эта система сравнивается с другими решениями для управления пациентами?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"В отличие от базовых инструментов планирования или выставления счетов, это решение включает портал для пациентов, мобильное приложение, интегрированный веб-сайт CMS, безопасную коммуникацию и встроенные рабочие процессы для согласия, обратной связи и записей — сокращая потребность в нескольких системах.\"}}]}"])</script><script>self.__next_f.push([1,"6:[[\"$\",\"$L11\",null,{\"id\":\"faq-schema\",\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"$21\"}}],\"$L22\",\"$L23\"]\n"])</script><script>self.__next_f.push([1,"25:I[51046,[\"9168\",\"static/chunks/app/%5Blocale%5D/platform/patient-administration/page-c637e41426a0282f.js\"],\"default\"]\n24:Tcff,"])</script><script>self.__next_f.push([1,"{\"@context\":\"https://schema.org\",\"@type\":\"SoftwareApplication\",\"@id\":\"https://www.continuouscare.io/ru/platform/patient-administration#software\",\"name\":\"ContinuousCare — Администрирование пациентов\",\"alternateName\":\"Универсальное управление пациентами для клиник\",\"url\":\"https://www.continuouscare.io/ru/platform/patient-administration\",\"image\":\"https://www.continuouscare.io/assets/patient-administration-hero.jpg\",\"description\":\"Программное обеспечение для администрирования пациентов для клиник, которое объединяет регистрацию и согласие, приемы и уведомления, выставление счетов и платежи, медицинские записи и безопасные коммуникации с пациентами. Включает брендированный портал для пациентов, мобильные приложения и веб-сайт клиники на основе CMS, привязанный к вашему домену.\",\"applicationCategory\":\"HealthApplication\",\"applicationSubCategory\":\"Patient management software; Practice management\",\"operatingSystem\":\"Web, iOS, Android\",\"inLanguage\":[\"ru\"],\"isAccessibleForFree\":fals