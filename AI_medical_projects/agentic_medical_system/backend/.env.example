# Application Settings
APP_ENV=development
PROJECT_NAME="Agentic Medical AI System"
VERSION=0.1.0
DEBUG=true

# API Settings
API_V1_STR=/api/v1
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"

# LLM Settings
OPENAI_API_KEY=""
DEFAULT_LLM_MODEL=gpt-4-turbo-preview
DEFAULT_LLM_TEMPERATURE=0.0
MAX_TOKENS=2000

# Security (JWT)
JWT_SECRET_KEY="please_change_this_to_a_secure_random_key"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=30

# Database (PostgreSQL)
POSTGRES_HOST=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=medical_agent_db
POSTGRES_PORT=5432
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10

# Langfuse Observability
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_HOST="https://cloud.langfuse.com"

# Rate Limiting
RATE_LIMIT_DEFAULT="200 per day,50 per hour"
RATE_LIMIT_CHAT="30 per minute"
RATE_LIMIT_CHAT_STREAM="20 per minute"
RATE_LIMIT_LOGIN="20 per minute"
